" 3  4  6 | 9  1  2 | 7  5  8\n"
"---------+---------+---------\n"
" 2  8  9 | 6  4  3 | 5  7  1\n"
" 5  7  3 | 2  9  1 | 6  8  4\n"
" 1  6  4 | 8  7  5 | 2  9  3\n"
