"      @list.from_array([\n"
"        Push(1),\n"
"        Eval,\n"
"        Push(1),\n"
"        Eval,\n"
"        Div,\n"
"        Update(2),\n"
"        Pop(2),\n"
"        Unwind,\n"
"      ]),\n"
"    ),\n"
"    // Compare\n"
"    (\n"
"      \"eq\",\n"
"      2,\n"
"      @list.from_array([\n"
