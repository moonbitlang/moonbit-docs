#: ../../pilot/moonbit-pilot/configuration.md:1
msgid "Configuration"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:3
msgid "Ignoring Files and Directories"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:5
msgid ""
"If you have directories or files that you want MoonBit Pilot to ignore, "
"you can configure this by placing a `.moonagentignore` file in your "
"project root directory. The format is identical to `.gitignore`."
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:7
msgid ""
"If no `.moonagentignore` file is set, MoonBit Pilot will use the "
"project's `.gitignore` as the default. Files excluded by either ignore "
"file will not be monitored by MoonBit Pilot."
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:9
msgid ".moonagentignore Format"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:11
msgid "The `.moonagentignore` file follows the same syntax as `.gitignore`:"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:13
msgid ""
"# Ignore specific files\n"
"secret.txt\n"
"config.local.json\n"
"\n"
"# Ignore directories\n"
"node_modules/\n"
".vscode/\n"
"dist/\n"
"\n"
"# Ignore file patterns\n"
"*.log\n"
"*.tmp\n"
"temp_*\n"
"\n"
"# Ignore nested patterns\n"
"docs/**/*.draft.md\n"
"\n"
"# Use ! to negate (include) previously ignored patterns\n"
"!important.log\n"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:35
msgid "Project Configuration"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:37
msgid "moonagent.yml"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:39
msgid ""
"Create a `.moonagent/moonagent.yml` file in your project root to "
"configure MoonBit Pilot's behavior:"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:41
msgid ""
"# MoonBit Pilot Project Configuration\n"
"# This configuration file controls moon pilot behavior for this project\n"
"\n"
"# Enable automatic commits when files are modified\n"
"auto_commit: true\n"
"\n"
"# Additional configuration options can be added here\n"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:51
msgid "Available Configuration Options"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:53
msgid ""
"**auto_commit**: When set to `true`, MoonBit Pilot will automatically "
"create git commits before and after making changes to your code"
msgstr ""

#: ../../pilot/moonbit-pilot/configuration.md:54
msgid "Additional configuration options may be added in future versions"
msgstr ""

