#: ../../pilot/moonbit-pilot/getting-started.md:46
msgid "Configuration Fields Explanation"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:48
msgid "**name**: A unique identifier for the model (used for reference)"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:49
msgid "**description**: Human-readable description of the model"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:50
msgid "**model_name**: The actual model identifier used by the API provider"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:51
msgid "**model_type**: Type of API interface (currently supports \"saas/openai\")"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:52
msgid "**base_url**: API endpoint URL for the model provider"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:53
msgid ""
"**is_reasoning**: Whether this is a reasoning model (affects token "
"counting)"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:54
msgid "**input_price**: Cost per million input tokens (in USD)"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:55
msgid "**output_price**: Cost per million output tokens (in USD)"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:56
msgid "**max_output_tokens**: Maximum number of tokens the model can output"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:57
msgid "**context_window**: Total context window size in tokens"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:58
msgid "**api_key**: Your API key for this provider"
msgstr ""

#: ../../pilot/moonbit-pilot/getting-started.md:60
msgid "About the Example Models"
msgstr ""

