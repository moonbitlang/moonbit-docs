#: ../../language/error_codes/E4084.md:1
msgid "E4084"
msgstr ""

#: ../../language/error_codes/E4084.md:3
msgid ""
"The label is supplied twice when calling a function with labelled "
"parameters."
msgstr ""

#: ../../language/error_codes/E4084.md:5
msgid "Erroneous Example"
msgstr ""

#: ../../language/error_codes/E4084.md:7
msgid ""
"///|\n"
"pub fn f(a~ : Int) -> Unit {\n"
"  println(\"Hello, \\{a}\")\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  f(a=0, a=1)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4084.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4084.md:13
msgid "If the call only needs one labelled argument, provide that label once."
msgstr ""

#: ../../language/error_codes/E4084.md:15
msgid ""
"///|\n"
"pub fn f(a~ : Int) -> Unit {\n"
"  println(\"Hello, \\{a}\")\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  f(a=0)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4084.md:19
msgid ""
"If the function has multiple labelled parameters and the duplicate label "
"came from a typo, change the duplicated label to the correct one."
msgstr ""

#: ../../language/error_codes/E4084.md:22
msgid ""
"///|\n"
"pub fn g(a~ : Int, b~ : Int) -> Unit {\n"
"  println(\"Hello, \\{a} and \\{b}\")\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  g(a=0, b=1)\n"
"}\n"
msgstr ""
