#: ../../language/error_codes/E4120.md:1
msgid "E4120"
msgstr ""

#: ../../language/error_codes/E4120.md:3
msgid "Compiler diagnostic name: `unhandled_error`."
msgstr ""

#: ../../language/error_codes/E4120.md:5
msgid "The application might raise errors, but they are not handled."
msgstr ""

#: ../../language/error_codes/E4120.md:7
msgid ""
"Current MoonBit reports the ordinary unhandled re-raise pattern as "
"[E4122](./E4122.md). This page is retained for older compiler output that"
" used E4120 with the deprecated postfix error-handling syntax."
msgstr ""

#: ../../language/error_codes/E4120.md:11
msgid ""
"In MoonBit, we require programmers to explicitly annotate which functions"
" may raise errors. A function that re-raises an error must use a `raise` "
"annotation in its signature. To keep the current function from raising, "
"handle the error with `try ... catch` or materialize it to a `Result[T, "
"E]` value with `try?`."
msgstr ""

#: ../../language/error_codes/E4120.md:16
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4120.md:18
msgid ""
"See [E4122](./E4122.md) for checked erroneous examples with the current "
"syntax."
msgstr ""

#: ../../language/error_codes/E4120.md:20
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4120.md:22
msgid "You can either annotate the caller so it re-raises the error:"
msgstr ""

#: ../../language/error_codes/E4120.md:24
msgid ""
"///|\n"
"pub suberror ExampleError {\n"
"  Failed\n"
"}\n"
"\n"
"///|\n"
"pub fn may_raise_error(input : Int) -> Unit raise ExampleError {\n"
"  if input == 42 {\n"
"    return\n"
"  }\n"
"  raise Failed\n"
"}\n"
"\n"
"///|\n"
"pub fn caller() -> Unit raise ExampleError {\n"
"  may_raise_error(42)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4120.md:28
msgid "Or materialize the error to a `Result[T, E]` type with `try?`:"
msgstr ""

#: ../../language/error_codes/E4120.md:30
msgid ""
"///|\n"
"pub fn materialize_error() -> Result[Unit, ExampleError] {\n"
"  try? may_raise_error(42)\n"
"}\n"
msgstr ""

#~ msgid ""
#~ "The application might raise errors, but"
#~ " it's not handled. Try adding an "
#~ "infix operator `!` or `?` to the"
#~ " application."
#~ msgstr ""

#~ msgid ""
#~ "In MoonBit, we require programmers to"
#~ " explicitly annotate which functions may"
#~ " raise errors. This is done by "
#~ "adding an infix operator `!` or "
#~ "`?` to the function application. The "
#~ "`!` operator to re-raise the "
#~ "error, and the `?` operator is to"
#~ " materialize the error to a "
#~ "`Result[T, E]` type."
#~ msgstr ""

#~ msgid ""
#~ "fn may_raise_error(input : Int) -> Unit! {\n"
#~ "  if input == 42 {\n"
#~ "    return\n"
#~ "  }\n"
#~ "  fail!(\"failed\")\n"
#~ "}\n"
#~ "\n"
#~ "fn main {\n"
#~ "  may_raise_error(42)\n"
#~ "  // Error: The application might "
#~ "raise errors of type Error, but "
#~ "it's not handled.\n"
#~ "  // Try adding a infix operator"
#~ " `!` or `?` to the application, "
#~ "so that it looks like `...!(...)` "
#~ "or `...?(...)`.\n"
#~ "}\n"
#~ msgstr ""

#~ msgid "You can either re-raise the error:"
#~ msgstr ""

#~ msgid ""
#~ "fn main {\n"
#~ "  try {\n"
#~ "    may_raise_error!(42)\n"
#~ "  } catch {\n"
#~ "    error => println(\"Error: \\{error}\")\n"
#~ "  }\n"
#~ "}"
#~ msgstr ""

#~ msgid "Or materialize the error to a `Result[T, E]` type:"
#~ msgstr ""

#~ msgid ""
#~ "fn main {\n"
#~ "  let result = may_raise_error?(42)\n"
#~ "  println(\"Result: \\{result}\")\n"
#~ "}"
#~ msgstr ""

