#: ../../language/error_codes/E0023.md:1
msgid "E0023"
msgstr ""

#: ../../language/error_codes/E0023.md:3
msgid "Warning name: `unused_try`"
msgstr ""

#: ../../language/error_codes/E0023.md:5
msgid "The body of this try expression never raises any error."
msgstr ""

#: ../../language/error_codes/E0023.md:7
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0023.md:9
msgid ""
"///|\n"
"fn main {\n"
"  println(\"Hello, world!\") catch { // `try` is omitted here\n"
"    _ => println(\"Error\")\n"
"  }\n"
"  try {\n"
"    println(\"Hello, \")\n"
"    println(\"world!\")\n"
"  } catch {\n"
"    _ => println(\"Error in try block\")\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0023.md:13
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0023.md:15
msgid "Remove the `try` expression:"
msgstr ""

#: ../../language/error_codes/E0023.md:17
msgid ""
"///|\n"
"fn main {\n"
"  println(\"Hello, world!\")\n"
"}\n"
msgstr ""

