"fn f(x: Bytes) -> Unit {\n"
"  match x {\n"
"    [0x12, u1be(_), 0x34, ..] => ()\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0059.md:17
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0059.md:19
msgid "Pad to the next byte boundary:"
msgstr ""

#: ../../language/error_codes/E0059.md:21
msgid ""
"fn f(x: Bytes) -> Unit {\n"
"  match x {\n"
"    [0x12, u1be(_), u7be(_), 0x34, ..] => ()\n"
