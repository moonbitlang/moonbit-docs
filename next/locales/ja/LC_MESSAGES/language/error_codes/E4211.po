#: ../../language/error_codes/E4211.md:1
msgid "E4211"
msgstr ""

#: ../../language/error_codes/E4211.md:3
msgid "Compiler diagnostic name: `control_in_list_comprehension`."
msgstr ""

#: ../../language/error_codes/E4211.md:5
msgid "Control flow is not allowed inside a list comprehension."
msgstr ""

#: ../../language/error_codes/E4211.md:7
msgid ""
"A list comprehension builds a new collection from the elements produced "
"by its clauses. Control operations such as `break`, `continue`, `return`,"
" `raise`, and `async` control do not have a surrounding loop or function "
"boundary inside the comprehension body that can consume them."
msgstr ""

#: ../../language/error_codes/E4211.md:12
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4211.md:14
msgid ""
"pub fn values() -> Array[Int] {\n"
"  label~: for ;; {\n"
"    let xs = [for _ in 0..<3 => { break label~ }]\n"
"    return xs\n"
"  }\n"
"  []\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4211.md:18
msgid ""
"The `break` appears inside the list comprehension body, so MoonBit "
"reports an error."
msgstr ""

#: ../../language/error_codes/E4211.md:21
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4211.md:23
msgid ""
"Move the control flow outside the comprehension, or rewrite the code as "
"an explicit loop."
msgstr ""

#: ../../language/error_codes/E4211.md:26
msgid ""
"pub fn values() -> Array[Int] {\n"
"  [for value in 0..<3 => value]\n"
"}\n"
msgstr ""

