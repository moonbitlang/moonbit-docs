#: ../../language/error_codes/E4212.md:1
msgid "E4212"
msgstr ""

#: ../../language/error_codes/E4212.md:3
msgid "Compiler diagnostic name: `invalid_moon_mod_config`."
msgstr ""

#: ../../language/error_codes/E4212.md:5
msgid "Invalid configuration in `moon.mod.json`."
msgstr ""

#: ../../language/error_codes/E4212.md:7
msgid ""
"`moon.mod.json` accepts only module-level configuration fields understood"
" by the build system. Unknown or misplaced configuration keys are "
"rejected so that spelling mistakes do not silently change how a module is"
" built."
msgstr ""

#: ../../language/error_codes/E4212.md:11
msgid ""
"This error is produced while the build system reads module configuration,"
" before ordinary `moon check` diagnostic rendering is available, so it is"
" not monitored by a source-level error-code example."
msgstr ""

#: ../../language/error_codes/E4212.md:15
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4212.md:17
msgid "{\"name\": \"moonbit-community/example\", \"invalid-config\": true}\n"
msgstr ""

#: ../../language/error_codes/E4212.md:21
msgid "The `invalid-config` field is not a valid module configuration key."
msgstr ""

#: ../../language/error_codes/E4212.md:23
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4212.md:25
msgid ""
"Remove the invalid field, or move package-level configuration to "
"`moon.pkg`."
msgstr ""

#: ../../language/error_codes/E4212.md:27
msgid "{\"name\": \"moonbit-community/example\"}\n"
msgstr ""
