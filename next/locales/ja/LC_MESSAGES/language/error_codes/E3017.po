#: ../../language/error_codes/E3017.md:1
msgid "E3017"
msgstr ""

#: ../../language/error_codes/E3017.md:3
msgid "Compiler diagnostic name: `json_parse_error`."
msgstr ""

#: ../../language/error_codes/E3017.md:5
msgid ""
"JSON parse error. This diagnostic is used for legacy JSON package "
"configuration files such as `moon.pkg.json`."
msgstr ""

#: ../../language/error_codes/E3017.md:8
msgid ""
"The current package configuration format is `moon.pkg`, which is not "
"JSON. If you still maintain a legacy `moon.pkg.json`, this error is "
"likely to be caused by a missing comma, a missing closing brace, or "
"another JSON syntax issue."
msgstr ""

#: ../../language/error_codes/E3017.md:12
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E3017.md:14
msgid ""
"{\n"
"  \"is-main\": true\n"
"  \"import\": [] // Error: Expect_comma_or_rbrace\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3017.md:21
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E3017.md:23
msgid ""
"Prefer migrating the package configuration to `moon.pkg`. If you must "
"keep the legacy JSON file for now, fix the JSON syntax."
msgstr ""

#: ../../language/error_codes/E3017.md:26
msgid ""
"This page has no checked source example because legacy JSON configuration"
" is parsed before ordinary `moon check` diagnostic rendering is "
"available."
msgstr ""

#: ../../language/error_codes/E3017.md:29
msgid ""
"{\n"
"  \"is-main\": true,\n"
"  \"import\": []\n"
"}\n"
msgstr ""
