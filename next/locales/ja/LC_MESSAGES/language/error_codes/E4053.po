#: ../../language/error_codes/E4053.md:1
msgid "E4053"
msgstr ""

#: ../../language/error_codes/E4053.md:3
msgid "Compiler diagnostic name: `invalid_self_type`."
msgstr ""

#: ../../language/error_codes/E4053.md:5
msgid "Invalid type for \"self\": must be a type constructor."
msgstr ""

#: ../../language/error_codes/E4053.md:7
msgid ""
"This error happens when you define a method or implement a trait for a "
"type that is not a type constructor."
msgstr ""

#: ../../language/error_codes/E4053.md:10
msgid "Types that **are** type constructors:"
msgstr ""

#: ../../language/error_codes/E4053.md:12
msgid "Tuple: `(Int, Bool)`"
msgstr ""

#: ../../language/error_codes/E4053.md:13
msgid ""
"`enum`s, `struct`s, `trait`s, new types (`type`), and error types "
"(`type!`)."
msgstr ""

#: ../../language/error_codes/E4053.md:15
msgid "Types that **are not** type constructors:"
msgstr ""

#: ../../language/error_codes/E4053.md:17
msgid "Function: `(Int) -> Bool`"
msgstr ""

#: ../../language/error_codes/E4053.md:18
msgid "Type parameter: `T` in `fn f[T](x : T) -> T`"
msgstr ""

#: ../../language/error_codes/E4053.md:20
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4053.md:22
msgid ""
"pub(open) trait T {\n"
"  f(Self) -> Unit\n"
"}\n"
"\n"
"impl T for (Int) -> Unit with f(self) {\n"
"  //                         ^\n"
"  // Error: Invalid type for \"self\": must be a type constructor.\n"
"  self(0)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4053.md:26
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4053.md:28
msgid ""
"Use a type constructor such as a struct, enum, trait, or new type. If you"
" need to attach methods to a function value, wrap the function in a named"
" type first."
msgstr ""

#: ../../language/error_codes/E4053.md:31
msgid ""
"pub(open) trait T {\n"
"  f(Self) -> Unit\n"
"}\n"
"\n"
"pub struct Handler {\n"
"  run : (Int) -> Unit\n"
"}\n"
"\n"
"impl T for Handler with f(self) {\n"
"  (self.run)(0)\n"
"}\n"
"\n"
"fn init {\n"
"  Handler::{ run: x => ignore(x) }.f()\n"
"}\n"
msgstr ""
