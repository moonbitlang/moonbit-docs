msgid "E4065"
msgstr ""

#: ../../language/error_codes/E4065.md:3
msgid "Overloaded operator should accept the correct number of arguments."
msgstr ""

#: ../../language/error_codes/E4065.md:5
msgid ""
"You can refer to the [Operator Overloading](../methods.md#operator-"
"overloading) section for a list of operators that can be overloaded, and "
"here is a list of number of arguments that each operator should accept:"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "Operator"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "Method Name"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "Number of Arguments"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "`_[_]`"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "`op_get`"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "2"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "`_[_] = _`"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "`op_set`"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "3"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "`_[_:_]`"
msgstr ""

#: ../../language/error_codes/E4065.md
msgid "`op_as_view`"
msgstr ""

#: ../../language/error_codes/E4065.md:15
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4065.md:17
msgid ""
"///|\n"
"struct A(Array[Int])\n"
"\n"
"///|\n"
"fn A::op_get(self : A, idx : Int, offset? : Int) -> Int {\n"
"  //  ^~~~~~\n"
"  // Error: overloaded operator \"op_get\" should accept 2 arguments, but"
" it accepts 3 arguments\n"
"  let idx = match offset {\n"
"    None => idx\n"
"    Some(offset) => idx + offset\n"
"  }\n"
"  return self.0[idx]\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4065.md:21
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4065.md:23
msgid ""
"Modify the method to match the expected number of arguments of the "
"operator."
msgstr ""

#: ../../language/error_codes/E4065.md:25
msgid ""
"///|\n"
"struct A(Array[Int])\n"
"\n"
"///|\n"
"fn A::op_get(self : A, idx : Int) -> Int {\n"
"  return self.0[idx]\n"
"}\n"
msgstr ""

