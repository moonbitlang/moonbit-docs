#~ "priv struct Point {\n"
#~ "  x : Int\n"
#~ "\n"
#~ "  fn new(Int) -> Point\n"
#~ "}\n"
#~ "\n"
#~ "///|\n"
#~ "fn Point::new(x : Int) -> Point {\n"
#~ "  { x, }\n"
#~ "}\n"
#~ "\n"
#~ "///|\n"
#~ "test {\n"
