#: ../../language/error_codes/E4198.md:1
msgid "E4198"
msgstr ""

#: ../../language/error_codes/E4198.md:3
msgid "Compiler diagnostic name: `struct_constr_not_implemented`."
msgstr ""

#: ../../language/error_codes/E4198.md:5
msgid ""
"When legacy code declares a constructor signature inside a `struct`, that"
" constructor must be implemented separately. The declaration only gives "
"the constructor signature; it does not create the implementation body."
msgstr ""

#: ../../language/error_codes/E4198.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4198.md:11
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"\n"
"  fn new(Int) -> Point\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4198.md:15
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4198.md:17
msgid "Define the constructor with the current top-level `Type::Type` form."
msgstr ""

#: ../../language/error_codes/E4198.md:19
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"}\n"
"\n"
"///|\n"
"fn Point::Point(x : Int) -> Point {\n"
"  { x, }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let point = Point(4)\n"
"  inspect(point.x, content=\"4\")\n"
"}\n"
msgstr ""

#~ msgid ""
#~ "Detailed documentation and examples for "
#~ "this diagnostic have not been added "
#~ "yet."
#~ msgstr ""

#~ msgid ""
#~ "When a `struct` declares a constructor"
#~ " signature, that constructor must be "
#~ "implemented as the corresponding `Type::new`"
#~ " method. The declaration only gives "
#~ "the constructor signature; it does not"
#~ " create the implementation body."
#~ msgstr ""

#~ msgid "Define the matching `Type::new` method."
#~ msgstr ""

#~ msgid ""
