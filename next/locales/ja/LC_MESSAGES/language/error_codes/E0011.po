#: ../../language/error_codes/E0011.md:1
msgid "E0011"
msgstr ""

#: ../../language/error_codes/E0011.md:3
msgid "Warning name: `partial_match`"
msgstr ""

#: ../../language/error_codes/E0011.md:5
msgid ""
"Partial match. The match/guard/loop expression does not cover all "
"possible cases."
msgstr ""

#: ../../language/error_codes/E0011.md:8
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0011.md:10
msgid ""
"///|\n"
"fn main {\n"
"  match Some(1) { // Partial match, some hints: None\n"
"    Some(x) => println(x)\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0011.md:14
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0011.md:16
msgid ""
"The warning message usually contains hints about the missing patterns. "
"Add the missing cases to avoid incomplete matches. You can use [quick "
"fix](https://code.visualstudio.com/docs/editing/refactoring#_code-"
"actions-quick-fixes-and-refactorings) when using [VSCode "
"Plugin](/toolchain/vscode/index.md#actions)."
msgstr ""

#: ../../language/error_codes/E0011.md:20
msgid ""
"///|\n"
"fn main {\n"
"  match Some(1) {\n"
"    Some(x) => println(x)\n"
"    None => println(\"None\")\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0011.md:24
msgid "Or, you can use `is` syntax to use this pattern matching as a condition:"
msgstr ""

#: ../../language/error_codes/E0011.md:26
msgid ""
"///|\n"
"/// Example using `is` syntax for conditional pattern matching\n"
"pub fn example_with_is() -> Unit {\n"
"  if Some(1) is Some(x) {\n"
"    println(x)\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0011.md:30
msgid "Or, you can add a wildcard pattern to catch all remaining cases:"
msgstr ""

#: ../../language/error_codes/E0011.md:32
msgid ""
"///|\n"
"/// Example using wildcard pattern to catch all remaining cases\n"
"pub fn example_with_wildcard() -> Unit {\n"
"  match Some(1) {\n"
"    Some(x) => println(x)\n"
"    _ => println(\"Other\")\n"
"  }\n"
"}\n"
msgstr ""

