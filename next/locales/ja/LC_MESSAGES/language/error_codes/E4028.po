#: ../../language/error_codes/E4028.md:1
msgid "E4028"
msgstr ""

#: ../../language/error_codes/E4028.md:3
msgid "This expression has a type which is not a struct."
msgstr ""

#: ../../language/error_codes/E4028.md:5
msgid "Erroneous Example"
msgstr ""

#: ../../language/error_codes/E4028.md:7
msgid ""
"struct T { a : Int }\n"
"let a : Int = { a: 42 }\n"
msgstr ""

#: ../../language/error_codes/E4028.md:12
msgid ""
"The example above tries to assign a struct of type `T` to a variable `a` "
"of type `Int`, which is not possible and gives the following error on "
"line 2:"
msgstr ""

#: ../../language/error_codes/E4028.md:15
msgid "This expression has type Int, which is a Int type and not a struct.\n"
msgstr ""

#: ../../language/error_codes/E4028.md:19
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4028.md:21
msgid "Make sure to use the correct type instead:"
msgstr ""

#: ../../language/error_codes/E4028.md:23
msgid ""
"struct T { a : Int }\n"
"let a : T = { a: 42 }"
msgstr ""

