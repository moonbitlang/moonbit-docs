#: ../../language/error_codes/E1000.md:1
msgid "E1000"
msgstr ""

#: ../../language/error_codes/E1000.md:3
msgid "Compiler diagnostic name: `swallow_error`."
msgstr ""

#: ../../language/error_codes/E1000.md:5
msgid ""
"This is an internal placeholder diagnostic. The compiler uses it while "
"recovering from an earlier type error so that follow-up errors can be "
"suppressed instead of reported as independent user-facing diagnostics."
msgstr ""

#: ../../language/error_codes/E1000.md:9
msgid ""
"You should not see E1000 in normal compiler output. If it appears in "
"rendered diagnostics, please report it as a compiler bug."
msgstr ""
