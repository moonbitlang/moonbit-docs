#: ../../language/error_codes/E4177.md:1
msgid "E4177"
msgstr ""

#: ../../language/error_codes/E4177.md:3
msgid "Extracting bytes sequence using bitstring pattern must be byte-aligned."
msgstr ""

#: ../../language/error_codes/E4177.md:5
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4177.md:7
msgid ""
"test {\n"
"  let a : Array[Byte] = [b'\\xFF', b'\\x00']\n"
"  match a {\n"
"    [u1be(flag), ..rest] => {\n"
"      inspect(flag, content=\"1\")\n"
"      inspect(rest.length(), content=\"1\")\n"
"    }\n"
"    _ => fail(\"\")\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4177.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4177.md:13
msgid "Align the bit pattern to full bytes before extracting a byte sequence."
msgstr ""

#: ../../language/error_codes/E4177.md:15
msgid ""
"test {\n"
"  let a : Array[Byte] = [b'\\xFF', b'\\x00']\n"
"  match a {\n"
"    [u8be(value), ..rest] => {\n"
"      inspect(value, content=\"255\")\n"
"      inspect(rest.length(), content=\"1\")\n"
"    }\n"
"    _ => fail(\"\")\n"
"  }\n"
"}\n"
msgstr ""

