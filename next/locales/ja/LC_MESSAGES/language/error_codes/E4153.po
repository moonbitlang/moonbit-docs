#: ../../language/error_codes/E4153.md:1
msgid "E4153"
msgstr ""

#: ../../language/error_codes/E4153.md:3
msgid "Duplicated tag in `enum` with custom tag value."
msgstr ""

#: ../../language/error_codes/E4153.md:5
msgid ""
"For constant `enum`, where all constructors have no payload, MoonBit "
"supports customizing the integer representation of constructors:"
msgstr ""

#: ../../language/error_codes/E4153.md:8
msgid ""
"enum Flag {\n"
"  A = 1\n"
"  B = 2\n"
"  C = 3\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4153.md:16
msgid ""
"However, the tag of each constructor must be unique, otherwise this error"
" will be reported."
msgstr ""

#: ../../language/error_codes/E4153.md:18
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4153.md:19
msgid ""
"enum Bad {\n"
"  A = 1\n"
"  B // the tag of `B` is `A + 1 = 2`\n"
"  C = 2 // duplicates with `B`\n"
"}"
msgstr ""

