#: ../../language/error_codes/E3007.md:1
msgid "E3007"
msgstr ""

#: ../../language/error_codes/E3007.md:3
msgid ""
"Wrong location of `..` in pattern match. Put `..` at the end of the "
"pattern."
msgstr ""

#: ../../language/error_codes/E3007.md:5
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E3007.md:7
msgid ""
"struct S {\n"
"  a : Int\n"
"  b : Int\n"
"  c : Int\n"
"}\n"
"\n"
"fn main {\n"
"  let s : S = { a : 1, b : 2, c : 3 }\n"
"  let { a, .., c } = s\n"
"  //       ^^\n"
"  // Error: Unexpected `..` here, add `, ..` behind the last field to "
"ignore the rest of struct.\n"
"}"
msgstr ""

#: ../../language/error_codes/E3007.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E3007.md:13
msgid ""
"// ...\n"
"fn main {\n"
"  // ...\n"
"  let { a, c, .. } = s\n"
"}"
msgstr ""

