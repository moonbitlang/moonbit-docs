#: ../../language/error_codes/E0031.md:1
msgid "E0031"
msgstr ""

#: ../../language/error_codes/E0031.md:3
msgid "Warning name: `unused_optional_argument`"
msgstr ""

#: ../../language/error_codes/E0031.md:5
msgid ""
"The optional argument is never supplied. If the optional argument is "
"never supplied, then it can be safely removed from the parameter list and"
" be used purely internally as a normal variable."
msgstr ""

#: ../../language/error_codes/E0031.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0031.md:11
msgid ""
"Note, this warning is turned off by default. To enable this warning, you "
"have to modify the `\"warn-list\"` of `moon.pkg.json`:"
msgstr ""

#: ../../language/error_codes/E0031.md:14
msgid "moon.pkg.json"
msgstr ""

#: ../../language/error_codes/E0031.md:14
msgid ""
"{\n"
"  \"is_main\": true,\n"
"  \"warn-list\": \"+unused_optional_argument\"\n"
"}"
msgstr ""

#: ../../language/error_codes/E0031.md:18
msgid "main.mbt"
msgstr ""

#: ../../language/error_codes/E0031.md:18
msgid ""
"///|\n"
"fn f(opt~ : Int = 4) -> Int {\n"
"  ignore(opt)\n"
"  0\n"
"}\n"
"\n"
"///|\n"
"fn main {\n"
"  println(f())\n"
"  println(f())\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0031.md:23
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0031.md:25
msgid ""
"You can remove the optional argument, and use a local variable definition"
" instead:"
msgstr ""

#: ../../language/error_codes/E0031.md:28
msgid ""
"///|\n"
"fn f() -> Int {\n"
"  let opt = 4\n"
"  ignore(opt)\n"
"  0\n"
"}\n"
"\n"
"///|\n"
"fn main {\n"
"  println(f())\n"
"  println(f())\n"
"}\n"
msgstr ""

