#: ../../language/error_codes/E4007.md:1
msgid "E4007"
msgstr ""

#: ../../language/error_codes/E4007.md:3
msgid ""
"Enum variants without payloads are considered as singleton values. "
"MoonBit does not allow such constructors to be called as functions."
msgstr ""

#: ../../language/error_codes/E4007.md:6
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4007.md:8
msgid ""
"enum Status {\n"
"  Done\n"
"  Pending\n"
"}\n"
"\n"
"fn main {\n"
"  let status = Done() // Error: constructor without payload cannot be "
"called with ()\n"
"}"
msgstr ""

#: ../../language/error_codes/E4007.md:12
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4007.md:14
msgid "Remove the function calling syntax from the constructor:"
msgstr ""

#: ../../language/error_codes/E4007.md:16
msgid ""
"// ...\n"
"fn main {\n"
"  let status = Done\n"
"}"
msgstr ""

#: ../../language/error_codes/E4007.md:20
msgid ""
"If you really need the constructor to construct values, explicitly use "
"`Unit` as its argument"
msgstr ""

#: ../../language/error_codes/E4007.md:23
msgid ""
"enum Status {\n"
"  Done(Unit)\n"
"  Pending\n"
"}\n"
"\n"
"fn main {\n"
"  let status = Done(())\n"
"}"
msgstr ""

