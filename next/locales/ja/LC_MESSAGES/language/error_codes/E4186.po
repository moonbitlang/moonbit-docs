#: ../../language/error_codes/E4186.md:1
msgid "E4186"
msgstr ""

#: ../../language/error_codes/E4186.md:3
msgid "Compiler diagnostic name: `guard_not_supported_in_longest_match_strategy`."
msgstr ""

#: ../../language/error_codes/E4186.md:5
msgid "Guards are not supported in longest-match `lexmatch` cases."
msgstr ""

#: ../../language/error_codes/E4186.md:7
msgid ""
"The longest-match strategy decides which regex case wins before running "
"the case body. Case guards would make that decision depend on arbitrary "
"expressions, so they are rejected for `lexmatch ... with longest`."
msgstr ""

#: ../../language/error_codes/E4186.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4186.md:13
msgid ""
"///|\n"
"pub fn match_text(text : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    \"abc\" if text.length() > 0 => ()\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4186.md:17
msgid "The first case has an `if` guard."
msgstr ""

#: ../../language/error_codes/E4186.md:19
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4186.md:21
msgid ""
"Move the condition into the case body so the longest-match decision "
"depends only on the regex patterns."
msgstr ""

#: ../../language/error_codes/E4186.md:24
msgid ""
"///|\n"
"pub fn match_text(text : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    \"abc\" => if text.length() > 0 { () }\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""

