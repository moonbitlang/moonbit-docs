#: ../../language/error_codes/E3018.md:1
msgid "E3018"
msgstr ""

#: ../../language/error_codes/E3018.md:3
msgid "Bounds of range pattern must be constant, named constant or wildcard."
msgstr ""

#: ../../language/error_codes/E3018.md:5
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E3018.md:7
msgid ""
"///|\n"
"fn describe(value : Int, limit : Int) -> String {\n"
"  match value {\n"
"    0..<limit => \"between\"\n"
"    _ => \"outside\"\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(describe(0, 3), content=\"between\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3018.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E3018.md:13
msgid "You can either lift the variable `a` to a named constant:"
msgstr ""

#: ../../language/error_codes/E3018.md:15
msgid ""
"///|\n"
"const A = 3\n"
"\n"
"///|\n"
"fn describe(value : Int) -> String {\n"
"  match value {\n"
"    0..<A => \"between\"\n"
"    _ => \"outside\"\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(describe(0), content=\"between\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3018.md:19
msgid "Or, you can use the constant value directly:"
msgstr ""

#: ../../language/error_codes/E3018.md:21
msgid ""
"///|\n"
"fn describe_literal(value : Int) -> String {\n"
"  match value {\n"
"    0..<3 => \"between\"\n"
"    _ => \"outside\"\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(describe_literal(0), content=\"between\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3018.md:25
msgid "Or, you can use a wildcard:"
msgstr ""

#: ../../language/error_codes/E3018.md:27
msgid ""
"///|\n"
"fn describe_wildcard(value : Int) -> String {\n"
"  match value {\n"
"    0..<_ => \"non-negative\"\n"
"    _ => \"negative\"\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(describe_wildcard(0), content=\"non-negative\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3018.md:31
msgid "Notice, using wildcard alters the meaning of this range pattern."
msgstr ""
