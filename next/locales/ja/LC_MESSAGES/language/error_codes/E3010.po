#: ../../language/error_codes/E3010.md:1
msgid "E3010"
msgstr ""

#: ../../language/error_codes/E3010.md:3
msgid "Only labelled arguments can have default value."
msgstr ""

#: ../../language/error_codes/E3010.md:5
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E3010.md:7
msgid ""
"pub fn greet(name : String = \"World\") -> Unit {\n"
"  //                       ^ Error: Only labelled arguments can have "
"default value.\n"
"  println(\"Hello, \" + name + \"!\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3010.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E3010.md:13
msgid "Use an optional argument with `?` if you want to provide a default value:"
msgstr ""

#: ../../language/error_codes/E3010.md:15
msgid ""
"///|\n"
"pub fn greet(name? : String = \"World\") -> Unit {\n"
"  println(\"Hello, \" + name + \"!\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3010.md:19
msgid ""
"Or remove the default value if you want to keep it as a positional "
"argument:"
msgstr ""

#: ../../language/error_codes/E3010.md:21
msgid ""
"///|\n"
"pub fn greet_without_default(name : String) -> Unit {\n"
"  println(\"Hello, \" + name + \"!\")\n"
"}\n"
msgstr ""

