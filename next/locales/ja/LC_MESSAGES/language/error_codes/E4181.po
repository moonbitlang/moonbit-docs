#: ../../language/error_codes/E4181.md:1
msgid "E4181"
msgstr ""

#: ../../language/error_codes/E4181.md:3
msgid ""
"Compiler diagnostic name: "
"`named_capture_in_regex_literal_used_in_lex_is_not_supported`."
msgstr ""

#: ../../language/error_codes/E4181.md:5
msgid ""
"Named capture groups are not supported in regex literals used by "
"`lexmatch`."
msgstr ""

#: ../../language/error_codes/E4181.md:7
msgid ""
"`lexmatch` can bind parts of a regex pattern through positional binders "
"in the lex pattern. Named capture groups inside the regex itself are "
"rejected because they are not part of the supported lex pattern binding "
"model."
msgstr ""

#: ../../language/error_codes/E4181.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4181.md:13
msgid ""
"///|\n"
"pub fn match_text(text : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    (\"(?<word>abc)\", _) => ()\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4181.md:17
msgid "The regex contains the named capture group `(?<word>...)`."
msgstr ""

#: ../../language/error_codes/E4181.md:19
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4181.md:21
msgid ""
"Use a normal regex group and bind the matched rest through the "
"surrounding lex pattern when needed."
msgstr ""

#: ../../language/error_codes/E4181.md:24
msgid ""
"///|\n"
"pub fn match_text(text : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    (\"abc\", _) => ()\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""
