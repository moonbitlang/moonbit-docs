#: ../../language/error_codes/E0008.md:1
msgid "E0008"
msgstr ""

#: ../../language/error_codes/E0008.md:3
msgid "Warning name: `redundant_modifier`"
msgstr ""

#: ../../language/error_codes/E0008.md:5
msgid ""
"The modifier (`pub`/`priv`) is redundant here, since this field has such "
"visibility by default."
msgstr ""

#: ../../language/error_codes/E0008.md:8
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0008.md:10
msgid ""
"///|\n"
"struct A {\n"
"  priv value : Int\n"
"  //^^\n"
"}\n"
"\n"
"///|\n"
"pub struct B {\n"
"  pub value : Int\n"
"  //^\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0008.md:14
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0008.md:16
msgid "Remove the visibility modifier on the field."
msgstr ""

#: ../../language/error_codes/E0008.md:18
msgid ""
"///|\n"
"struct A {\n"
"  value : Int\n"
"}\n"
"\n"
"///|\n"
"pub struct B {\n"
"  value : Int\n"
"}\n"
msgstr ""

