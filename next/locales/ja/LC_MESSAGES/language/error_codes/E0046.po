#: ../../language/error_codes/E0046.md:1
msgid "E0046"
msgstr ""

#: ../../language/error_codes/E0046.md:3
msgid "Warning name: `unused_rest_mark`"
msgstr ""

#: ../../language/error_codes/E0046.md:5
msgid "Useless `..` in struct or constructor pattern."
msgstr ""

#: ../../language/error_codes/E0046.md:7
msgid ""
"`..` can be used to ignore unmatched fields in struct pattern, or ignore "
"unmatched labelled arguments in constructor pattern. But if all "
"fields/labelled arguments are already matched, the `..` is useless, and "
"this warning will be emitted."
msgstr ""

#: ../../language/error_codes/E0046.md:12
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0046.md:14
msgid ""
"///|\n"
"struct Point {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"///|\n"
"fn f(p : Point) -> Unit {\n"
"  let { x, y, .. } = p\n"
"  println(x + y)\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  f({ x: 1, y: 2 })\n"
"}\n"
msgstr ""

