#: ../../language/error_codes/E4215.md:1
msgid "E4215"
msgstr ""

#: ../../language/error_codes/E4215.md:3
msgid "Compiler diagnostic name: `expect_template_string`."
msgstr ""

#: ../../language/error_codes/E4215.md:5
msgid "Template writing expects a string template."
msgstr ""

#: ../../language/error_codes/E4215.md:7
msgid ""
"The `<+` template-writing operator writes a string template to the value "
"on its left. The right-hand side must be a string literal, an "
"interpolated string, or a multiline string template. Other expressions "
"cannot be expanded as template content."
msgstr ""

#: ../../language/error_codes/E4215.md:12
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4215.md:14
msgid ""
"pub fn render(value : String) -> String {\n"
"  let builder = StringBuilder::new()\n"
"  builder <+ value\n"
"  builder.to_string()\n"
"}\n"
msgstr ""
#: ../../language/error_codes/E4215.md:18
msgid "The right-hand side is a variable reference, not a template string."
msgstr ""

#: ../../language/error_codes/E4215.md:20
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4215.md:22
msgid "Use a string template on the right-hand side."
msgstr ""

#: ../../language/error_codes/E4215.md:24
msgid ""
"pub fn render(value : String) -> String {\n"
"  let builder = StringBuilder::new()\n"
"  builder <+ \"\\{value}\"\n"
"  builder.to_string()\n"
"}\n"
msgstr ""
