#: ../../language/error_codes/E4197.md:1
msgid "E4197"
msgstr ""

#: ../../language/error_codes/E4197.md:3
msgid "Compiler diagnostic name: `cannot_match_struct_constr`."
msgstr ""

#: ../../language/error_codes/E4197.md:5
msgid ""
"A constructor declared by a `struct` is a constructor function, not a "
"pattern constructor. It can be called to create a value, but it cannot be"
" used in a `match` pattern."
msgstr ""

#: ../../language/error_codes/E4197.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4197.md:11
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"\n"
"  fn new(Int) -> Point\n"
"}\n"
"\n"
"///|\n"
"fn Point::new(x : Int) -> Point {\n"
"  { x, }\n"
"}\n"
"\n"
"///|\n"
"fn read(point : Point) -> Int {\n"
"  match point {\n"
"    Point(x) => x\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let _ = read(Point(1))\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4197.md:15
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4197.md:17
msgid ""
"Read the struct fields directly, or use another pattern that does not "
"call the constructor function."
msgstr ""

#: ../../language/error_codes/E4197.md:20
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"\n"
"  fn new(Int) -> Point\n"
"}\n"
"\n"
"///|\n"
"fn Point::new(x : Int) -> Point {\n"
"  { x, }\n"
"}\n"
"\n"
"///|\n"
"fn read(point : Point) -> Int {\n"
"  point.x\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(read(Point(3)), content=\"3\")\n"
"}\n"
msgstr ""

