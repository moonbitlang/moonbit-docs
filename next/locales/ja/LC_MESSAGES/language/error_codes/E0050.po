#: ../../language/error_codes/E0050.md:1
msgid "E0050"
msgstr ""

#: ../../language/error_codes/E0050.md:3
msgid "Warning name: `method_shadowing`"
msgstr ""

#: ../../language/error_codes/E0050.md:5
msgid "Local method shadows upstream method."
msgstr ""

#: ../../language/error_codes/E0050.md:7
msgid ""
"Methods can be defined for types that does not belong to the current "
"package. When having the same name as the existing ones, it can lead to "
"confusion about which method is being referenced."
msgstr ""

#: ../../language/error_codes/E0050.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0050.md:13
msgid ""
"///|\n"
"fn Int::abs(i : Int) -> Int {\n"
"  if i > 0 {\n"
"    i\n"
"  } else {\n"
"    -i\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect((-1).abs(), content=\"1\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0050.md:17
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0050.md:19
msgid "Use distinct names for local methods to make the code's intent clear."
msgstr ""

#: ../../language/error_codes/E0050.md:21
msgid ""
"///|\n"
"fn Int::local_abs(i : Int) -> Int {\n"
"  if i > 0 {\n"
"    i\n"
"  } else {\n"
"    -i\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect((-1).local_abs(), content=\"1\")\n"
"}\n"
msgstr ""

