#: ../../language/error_codes/E0056.md:1
msgid "E0056"
msgstr ""

#: ../../language/error_codes/E0056.md:3
msgid "Warning name: `missing_pattern_field`"
msgstr ""

#: ../../language/error_codes/E0056.md:5
msgid "Missing field in struct pattern."
msgstr ""

#: ../../language/error_codes/E0056.md:7
msgid ""
"The warning is emitted when pattern matching on a [struct "
"pattern](/language/fundamentals.md#simple-patterns) and having missing "
"fields."
msgstr ""

#: ../../language/error_codes/E0056.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0056.md:13
msgid ""
"///|\n"
"struct Point {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"///|\n"
"pub fn quadrant(p : Point) -> String {\n"
"  match p {\n"
"    { x: _..<0 } => \"Third or Fourth Quadrant\"\n"
"    { x: 0..<_ } => \"First or Second Quadrant\"\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0056.md:17
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0056.md:19
msgid "Add `..` if you want to omit the other fields, or use them."
msgstr ""

#: ../../language/error_codes/E0056.md:21
msgid ""
"///|\n"
"struct Point {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"///|\n"
"pub fn quadrant(p : Point) -> String {\n"
"  match p {\n"
"    { x: _..<0, .. } => \"Third or Fourth Quadrant\"\n"
"    { x: 0..<_, y: 0..<_ } => \"First Quadrant\"\n"
"    { x: 0..<_, y: _..<0 } => \"Second Quadrant\"\n"
"  }\n"
"}\n"
msgstr ""

