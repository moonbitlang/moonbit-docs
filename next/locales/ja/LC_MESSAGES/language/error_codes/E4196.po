#: ../../language/error_codes/E4196.md:1
msgid "E4196"
msgstr ""

#: ../../language/error_codes/E4196.md:3
msgid "Compiler diagnostic name: `where_clause_reasoning_not_string`."
msgstr ""

#: ../../language/error_codes/E4196.md:5
msgid ""
"The `proof_reasoning` field in a `where` clause records explanatory text "
"for the proof. Its value must be a string literal or a multiline string "
"literal, not a variable or another expression."
msgstr ""

#: ../../language/error_codes/E4196.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4196.md:11
msgid ""
"///|\n"
"fn keep(\n"
"  x : Int,\n"
") -> Int where {\n"
"  proof_ensure: result => result == x,\n"
"  proof_reasoning: x,\n"
"} {\n"
"  x\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  ignore(keep)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4196.md:15
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4196.md:17
msgid "Use a string literal for `proof_reasoning`."
msgstr ""

#: ../../language/error_codes/E4196.md:19
msgid ""
"///|\n"
"fn keep(\n"
"  x : Int,\n"
") -> Int where {\n"
"  proof_ensure: result => result == x,\n"
"  proof_reasoning: \"The function returns its argument unchanged.\",\n"
"} {\n"
"  x\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(keep(2), content=\"2\")\n"
"}\n"
msgstr ""

