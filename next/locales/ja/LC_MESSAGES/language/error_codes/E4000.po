#: ../../language/error_codes/E4000.md:1
msgid "E4000"
msgstr ""

#: ../../language/error_codes/E4000.md:3
msgid "Generic type variable name is already used."
msgstr ""

#: ../../language/error_codes/E4000.md:5
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4000.md:7
msgid ""
"///|\n"
"struct Container[T, T] {\n"
"  value : T\n"
"}\n"
"\n"
"///|\n"
"fn[A, A] transform(x : A) -> A {\n"
"  x\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4000.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4000.md:13
msgid "Use different names for type variables:"
msgstr ""

#: ../../language/error_codes/E4000.md:15
msgid ""
"///|\n"
"priv struct Container[T1, T2] {\n"
"  first : T1\n"
"  second : T2\n"
"}\n"
"\n"
"///|\n"
"fn[A, B] transform(x : A, f : (A) -> B) -> B {\n"
"  f(x)\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let container : Container[Int, String] = { first: 1, second: \"one\" }\n"
"  inspect(container.first, content=\"1\")\n"
"  inspect(container.second, content=\"one\")\n"
"  inspect(transform(1, fn(x) { x.to_string() }), content=\"1\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4000.md:19
msgid "Or remove the duplicate type parameter if you meant to use the same type:"
msgstr ""

#: ../../language/error_codes/E4000.md:21
msgid ""
"///|\n"
"priv struct Box[T] {\n"
"  value : T\n"
"}\n"
"\n"
"///|\n"
"fn[A] identity(x : A) -> A {\n"
"  x\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let container : Box[Int] = { value: 1 }\n"
"  inspect(container.value, content=\"1\")\n"
"  inspect(identity(\"value\"), content=\"value\")\n"
"}\n"
msgstr ""

