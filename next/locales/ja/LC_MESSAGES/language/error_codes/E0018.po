#: ../../language/error_codes/E0018.md:1
msgid "E0018"
msgstr ""

#: ../../language/error_codes/E0018.md:3
msgid "Warning name: `useless_loop`"
msgstr ""

#: ../../language/error_codes/E0018.md:5
msgid "There is no `continue` in this loop expression, so `loop` is useless here."
msgstr ""

#: ../../language/error_codes/E0018.md:7
msgid ""
"This error occurs when using a `loop` expression that contains no "
"`continue` statement. In MoonBit, a `loop` without any `continue` "
"statements is equivalent to an block expression that will be executed "
"only once, making the `loop` keyword redundant in such cases. You should "
"either add a `continue` statement if you need to restart the loop from "
"the beginning, or use a simpler control flow construct like `match` or "
"`if`."
msgstr ""

#: ../../language/error_codes/E0018.md:14
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0018.md:16
msgid ""
"///|\n"
"fn main {\n"
"  let count = 2\n"
"  loop count {\n"
"    _..<0 => break\n"
"    _ => println(count)\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0018.md:24
#: ../../language/error_codes/E0018.md:41
#: ../../language/error_codes/E0018.md:56
msgid "Output:"
msgstr ""

#: ../../language/error_codes/E0018.md:26
#: ../../language/error_codes/E0018.md:58
msgid "2\n"
msgstr ""

#: ../../language/error_codes/E0018.md:29
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0018.md:31
msgid "Either add a `continue` statement if you need to restart the loop:"
msgstr ""

#: ../../language/error_codes/E0018.md:33
msgid ""
"///|\n"
"fn main {\n"
"  let count = 2\n"
"  loop count {\n"
"    _..<0 => break\n"
"    count => {\n"
"      println(count)\n"
"      continue count - 1\n"
"    }\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0018.md:43
msgid ""
"2\n"
"1\n"
"0\n"
msgstr ""

#: ../../language/error_codes/E0018.md:46
msgid "Or use `if`/`match` you don't need to use `continue`:"
msgstr ""

#: ../../language/error_codes/E0018.md:48
msgid ""
"///|\n"
"fn main {\n"
"  let count = 2\n"
"  match count {\n"
"    _..<0 => ()\n"
"    _ => println(count)\n"
"  }\n"
"}\n"
msgstr ""

