#: ../../language/error_codes/E4044.md:1
msgid "E4044"
msgstr ""

#: ../../language/error_codes/E4044.md:3
msgid "Compiler diagnostic name: `missing_fields_in_record`."
msgstr ""

#: ../../language/error_codes/E4044.md:5
msgid "Struct or record fields are missing."
msgstr ""

#: ../../language/error_codes/E4044.md:7
msgid ""
"When constructing a struct value, every required field must be provided. "
"When matching a struct pattern, either list all fields that matter or use"
" `..` to ignore the rest."
msgstr ""

#: ../../language/error_codes/E4044.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4044.md:13
msgid ""
"pub(all) struct S {\n"
"  a : Int\n"
"  b : Int\n"
"}\n"
"\n"
"pub let s : S = { a: 1 }\n"
"//              ^~~~~~~~\n"
"// Error: Record fields b are undefined for type S\n"
msgstr ""

#: ../../language/error_codes/E4044.md:17
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4044.md:19
msgid "Provide all required fields in the struct value."
msgstr ""

#: ../../language/error_codes/E4044.md:21
msgid ""
"pub(all) struct S {\n"
"  a : Int\n"
"  b : Int\n"
"}\n"
"\n"
"pub let s : S = { a: 1, b: 2 }\n"
msgstr ""
