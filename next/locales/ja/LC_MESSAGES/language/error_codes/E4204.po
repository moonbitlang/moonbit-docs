#: ../../language/error_codes/E4204.md:1
msgid "E4204"
msgstr ""

#: ../../language/error_codes/E4204.md:3
msgid "Compiler diagnostic name: `loop_nobreak_not_supported`."
msgstr ""

#: ../../language/error_codes/E4204.md:5
msgid ""
"The `loop` expression does not support a `nobreak` block. `nobreak` is "
"for loop forms where normal completion is possible, while `loop` is an "
"explicit functional loop that continues or breaks from its body."
msgstr ""

#: ../../language/error_codes/E4204.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4204.md:11
msgid ""
"///|\n"
"fn count_down(n : Int) -> Int {\n"
"  loop n {\n"
"    0 => break 0\n"
"    i => continue i - 1\n"
"  } nobreak {\n"
"    -1\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  ignore(count_down)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4204.md:15
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4204.md:17
msgid ""
"Rewrite the code as a `for` loop when you need loop state and an explicit"
" result."
msgstr ""

#: ../../language/error_codes/E4204.md:20
msgid ""
"///|\n"
"fn count_down(n : Int) -> Int {\n"
"  for i = n {\n"
"    if i == 0 {\n"
"      break 0\n"
"    }\n"
"    continue i - 1\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(count_down(3), content=\"0\")\n"
"}\n"
msgstr ""

