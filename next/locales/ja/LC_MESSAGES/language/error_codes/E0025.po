#: ../../language/error_codes/E0025.md:1
msgid "E0025"
msgstr ""

#: ../../language/error_codes/E0025.md:3
msgid "Warning name: `test_unqualified_package`"
msgstr ""

#: ../../language/error_codes/E0025.md:5
msgid "Using implicitly imported API in test."
msgstr ""

#: ../../language/error_codes/E0025.md:7
msgid ""
"This warning is emitted when a test uses an API that is implicitly "
"imported. Prefer adding an explicit import or qualifying the name to make"
" the dependency clear."
msgstr ""

#: ../../language/error_codes/E0025.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0025.md:13
msgid ""
"// blackbox test (no import, unqualified use)\n"
"\n"
"test {\n"
"  inspect(add(1, 2), content=\"3\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0025.md:17
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0025.md:19
msgid "Use a qualified package name in blackbox tests:"
msgstr ""

#: ../../language/error_codes/E0025.md:21
msgid ""
"// blackbox test with qualified package use\n"
"\n"
"test {\n"
"  inspect(@E0025.add(1, 2), content=\"3\")\n"
"}\n"
msgstr ""

