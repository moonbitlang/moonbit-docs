#: ../../language/error_codes/E4057.md:1
msgid "E4057"
msgstr ""

#: ../../language/error_codes/E4057.md:3
msgid "Compiler diagnostic name: `constructor_duplicate`."
msgstr ""

#: ../../language/error_codes/E4057.md:5
msgid ""
"The constructor is duplicate. Constructors in the same enum must have "
"unique names so construction and pattern matching can identify one "
"variant unambiguously."
msgstr ""

#: ../../language/error_codes/E4057.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4057.md:11
msgid ""
"///|\n"
"enum E {\n"
"  A\n"
"  A(Int)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4057.md:15
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4057.md:17
msgid "Rename the constructor to a different name."
msgstr ""

#: ../../language/error_codes/E4057.md:19
msgid ""
"///|\n"
"priv enum E {\n"
"  A\n"
"  B(Int)\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let value = E::B(1)\n"
"  ignore(E::A)\n"
"  match value {\n"
"    A => inspect(\"A\")\n"
"    B(n) => inspect(n, content=\"1\")\n"
"  }\n"
"}\n"
msgstr ""
