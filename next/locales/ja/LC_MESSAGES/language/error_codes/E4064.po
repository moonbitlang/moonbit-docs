#: ../../language/error_codes/E4064.md:3
msgid "Invalid escape sequence in char/string literal."
msgstr ""

#: ../../language/error_codes/E4064.md:5
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4064.md:7
msgid ""
"Using escape sequence with invalid unicode code point result in this "
"error:"
msgstr ""

#: ../../language/error_codes/E4064.md:9
msgid ""
"test {\n"
"  println('\\uD800')\n"
"}"
msgstr ""

#: ../../language/error_codes/E4064.md:13
msgid ""
"Another case is using unsupported escape sequence in char literal for "
"`Byte`:"
msgstr ""

#: ../../language/error_codes/E4064.md:15
msgid ""
"test {\n"
"  let _ : Byte = '\\uD000'\n"
"}"
msgstr ""

#: ../../language/error_codes/E4064.md:19
msgid "Only `\\x` and `\\o` escape sequences are supported in `Byte` literal."
msgstr ""

