#: ../../language/error_codes/E4138.md:1
msgid "E4138"
msgstr ""

#: ../../language/error_codes/E4138.md:3
msgid ""
"Range operators only support builtin integer types, they cannot be used "
"on this type."
msgstr ""

#: ../../language/error_codes/E4138.md:6
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4138.md:8
msgid "For example, you cannot use `Float` nor `Double` with range operators."
msgstr ""

#: ../../language/error_codes/E4138.md:10
msgid ""
"fn main {\n"
"  for f in 0.0..<1.0 {\n"
"  }\n"
"}"
msgstr ""

#: ../../language/error_codes/E4138.md:14
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4138.md:16
msgid ""
"Use integer types for the range operators, and generate floats from these"
" integers instead:"
msgstr ""

#: ../../language/error_codes/E4138.md:19
msgid ""
"fn main {\n"
"  for i in 0..<10 {\n"
"    println(i.to_float())\n"
"  }\n"
"}"
msgstr ""

#: ../../language/error_codes/E4138.md:23
msgid "You can also use `until` to construct a range of numbers:"
msgstr ""

#: ../../language/error_codes/E4138.md:25
msgid ""
"fn main {\n"
"  let range : Iter[Double] = (0.0).until(10.0)\n"
"  for i in range {\n"
"    println(i)\n"
"  }\n"
"}"
msgstr ""

