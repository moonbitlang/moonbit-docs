#: ../../language/error_codes/E4029.md:1
msgid "E4029"
msgstr ""

#: ../../language/error_codes/E4029.md:3
msgid "This expression has a type which is not a variant."
msgstr ""

#: ../../language/error_codes/E4029.md:5
msgid "Erroneous Example"
msgstr ""

#: ../../language/error_codes/E4029.md:7
msgid ""
"pub(all) struct T {\n"
"  value : Int\n"
"}\n"
"\n"
"pub fn check(value : Int?) -> Int {\n"
"  match value {\n"
"    T::None => 0\n"
"    Some(value) => value\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4029.md:11
msgid ""
"The example above tries to use `T::None` as a constructor pattern, but "
"`T` is a struct type, not an enum or enumview type, giving the following "
"error on line 5:"
msgstr ""

#: ../../language/error_codes/E4029.md:15
msgid "The type T is a struct type and not an enum or enumview.\n"
msgstr ""

#: ../../language/error_codes/E4029.md:19
msgid "Suggestions"
msgstr ""

#: ../../language/error_codes/E4029.md:21
msgid "Make sure to use a value of the correct type instead:"
msgstr ""

#: ../../language/error_codes/E4029.md:23
msgid ""
"pub fn check(value : Int?) -> Int {\n"
"  match value {\n"
"    None => 0\n"
"    Some(value) => value\n"
"  }\n"
"}\n"
msgstr ""
