#: ../../language/error_codes/E4171.md:1
msgid "E4171"
msgstr ""

#: ../../language/error_codes/E4171.md:3
msgid "Compiler diagnostic name: `last_regex_case_must_be_catchall`."
msgstr ""

#: ../../language/error_codes/E4171.md:5
msgid "The last case in a `lexmatch` expression must be a catch-all pattern."
msgstr ""

#: ../../language/error_codes/E4171.md:7
msgid ""
"MoonBit checks `lexmatch` expressions for exhaustiveness. When all "
"previous regex patterns fail, the expression still needs a final branch "
"that can handle the remaining input."
msgstr ""

#: ../../language/error_codes/E4171.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4171.md:13
msgid ""
"///|\n"
"pub fn match_text(text : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    \"abc\" => ()\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4171.md:17
msgid "The only branch matches `\"abc\"`, so other input has no branch to run."
msgstr ""

#: ../../language/error_codes/E4171.md:19
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4171.md:21
msgid ""
"Add a final `_` case, or otherwise make the last case catch all remaining"
" input."
msgstr ""

#: ../../language/error_codes/E4171.md:23
msgid ""
"///|\n"
"pub fn match_text(text : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    \"abc\" => ()\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""
