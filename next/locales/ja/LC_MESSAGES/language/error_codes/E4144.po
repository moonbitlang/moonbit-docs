#: ../../language/error_codes/E4144.md:1
msgid "E4144"
msgstr ""

#: ../../language/error_codes/E4144.md:3
msgid "This is a constant, not a constructor, it cannot be applied to arguments."
msgstr ""

#: ../../language/error_codes/E4144.md:5
msgid ""
"This error occurs when you try to use a constant as a constructor in "
"pattern. One possible reason for this error is that you have a constant "
"with the same name as an constructor from some other packages, and in "
"such case you need to either use qualified name or type annotations to "
"disambiguate."
msgstr ""

#: ../../language/error_codes/E4144.md:10
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4144.md:12
msgid ""
"pub const Value : Int = 1\n"
"\n"
"pub fn classify(value : Int) -> String {\n"
"  match value {\n"
"    Value(_) => \"Value\"\n"
"  //^~~~~\n"
"  // Error: 'Value' is a constant, not a constructor, it cannot be "
"applied to arguments.\n"
"    _ => \"Other\"\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4144.md:16
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4144.md:18
msgid ""
"If you want to match against the constant, you can remove the payload "
"from the pattern."
msgstr ""

#: ../../language/error_codes/E4144.md:21
msgid ""
"pub const Value : Int = 1\n"
"\n"
"pub fn classify(value : Int) -> String {\n"
"  match value {\n"
"    Value => \"Value\"\n"
"    _ => \"Other\"\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4144.md:25
msgid ""
"Or if the constant has the same name as a constructor from some other "
"packages, you can use qualified name or type annotations to disambiguate."
msgstr ""

#: ../../language/error_codes/E4144.md:28
msgid ""
"pub fn classify_qualified(item : @a.Item) -> String {\n"
"  match item {\n"
"    @a.Value(_) => \"Value\"\n"
"  }\n"
"}\n"
msgstr ""
