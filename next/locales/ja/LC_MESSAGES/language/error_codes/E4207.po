#: ../../language/error_codes/E4207.md:1
msgid "E4207"
msgstr ""

#: ../../language/error_codes/E4207.md:3
msgid "Compiler diagnostic name: `invalid_predicate`."
msgstr ""

#: ../../language/error_codes/E4207.md:5
msgid "Invalid predicate expression."
msgstr ""

#: ../../language/error_codes/E4207.md:7
msgid ""
"Quantifiers and other proof-only predicate forms are part of MoonBit's "
"verification language. They are valid in proof positions such as "
"`proof_assert`, contracts, and `.mbtp` predicate definitions, but they "
"cannot be used as ordinary runtime expressions."
msgstr ""

#: ../../language/error_codes/E4207.md:12
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4207.md:14
msgid ""
"The following example tries to bind a quantified predicate as an ordinary"
" value:"
msgstr ""

#: ../../language/error_codes/E4207.md:16
msgid ""
"///|\n"
"fn invalid_predicate() -> Unit {\n"
"  let _ = ∀ i : Int, 0 <= i\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  ignore(invalid_predicate)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4207.md:20
msgid "MoonBit will report an error."
msgstr ""

#: ../../language/error_codes/E4207.md:22
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4207.md:24
msgid "Move the predicate into a proof position such as `proof_assert`:"
msgstr ""

#: ../../language/error_codes/E4207.md:26
msgid ""
"///|\n"
"fn checked_predicate() -> Unit {\n"
"  proof_assert ∀ i : Int, i == i\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  checked_predicate()\n"
"}\n"
msgstr ""
