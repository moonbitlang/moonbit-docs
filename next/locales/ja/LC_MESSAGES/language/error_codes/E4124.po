#: ../../language/error_codes/E4124.md:1
msgid "E4124"
msgstr ""

#: ../../language/error_codes/E4124.md:3
msgid "The constructor is ambiguous: it may come from multiple types."
msgstr ""

#: ../../language/error_codes/E4124.md:5
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4124.md:7
msgid ""
"pub enum A {\n"
"  A(Int)\n"
"  B(Bool)\n"
"  C(Double)\n"
"}\n"
"\n"
"pub enum B {\n"
"  A(Double)\n"
"  B(Int)\n"
"  C(Bool)\n"
"}\n"
"\n"
"pub fn use_a() -> Unit {\n"
"  ignore(A(1))\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4124.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4124.md:13
msgid "Add `T::` before the constructor:"
msgstr ""

#: ../../language/error_codes/E4124.md:15
msgid ""
"pub enum A {\n"
"  A(Int)\n"
"  B(Bool)\n"
"  C(Double)\n"
"}\n"
"\n"
"pub enum B {\n"
"  A(Double)\n"
"  B(Int)\n"
"  C(Bool)\n"
"}\n"
"\n"
"pub fn use_all() -> (A, A, A, B, B, B) {\n"
"  (\n"
"    A::A(1),\n"
"    A::B(true),\n"
"    A::C(1.0),\n"
"    B::A(1.0),\n"
"    B::B(1),\n"
"    B::C(true),\n"
"  )\n"
"}\n"
msgstr ""
