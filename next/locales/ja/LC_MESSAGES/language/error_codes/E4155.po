#: ../../language/error_codes/E4155.md:1
msgid "E4155"
msgstr ""

#: ../../language/error_codes/E4155.md:3
msgid "Cycle in `const`, `fnalias`, `typealias` or `traitalias` declaration."
msgstr ""

#: ../../language/error_codes/E4155.md:5
msgid ""
"`const` declaration can refer to other constants defined in the same "
"package, and `fnalias` can alias other function alias in the same "
"package, too. `typealias` and `traitalias` can also refer to other "
"`typealias`/`traitalias` in current package. But these definitions must "
"not form cycle, otherwise this error will be reported."
msgstr ""

#: ../../language/error_codes/E4155.md:10
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4155.md:11
msgid ""
"///|\n"
"const A : Int = B + 1\n"
"\n"
"///|\n"
"const B : Int = A + 1\n"
"\n"
"///|\n"
"fnalias f as g\n"
"\n"
"///|\n"
"fnalias g as f\n"
"\n"
"///|\n"
"typealias T1 as T2\n"
"\n"
"///|\n"
"typealias T2 as T1\n"
"\n"
"///|\n"
"traitalias I1 as I2\n"
"\n"
"///|\n"
"traitalias I2 as I1\n"
msgstr ""

