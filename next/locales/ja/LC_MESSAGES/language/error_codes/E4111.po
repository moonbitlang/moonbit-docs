#: ../../language/error_codes/E4111.md:1
msgid "E4111"
msgstr ""

#: ../../language/error_codes/E4111.md:3
msgid "The usage of break statement is invalid."
msgstr ""

#: ../../language/error_codes/E4111.md:5
msgid ""
"This error happens when you use a `break` statement in the "
"initialization, condition, or update statement of a loop."
msgstr ""

#: ../../language/error_codes/E4111.md:8
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4111.md:10
msgid ""
"///|\n"
"pub fn f(x : Int, y : Int) -> Unit {\n"
"  for i = 0; i < x; i = i + 1 {\n"
"    for j = ({\n"
"            break\n"
"          })\n"
"        j < y\n"
"        j = j + 1 {\n"
"      //            ^^^^^ Error: The usage of break statement is invalid."
"\n"
"      println(i + j)\n"
"    }\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4111.md:14
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4111.md:16
msgid ""
"Do not write a `break` statement in the initialization, condition, or "
"update statement of a loop. Put it in the loop body instead."
msgstr ""

#: ../../language/error_codes/E4111.md:19
msgid ""
"///|\n"
"pub fn f(x : Int, y : Int) -> Unit {\n"
"  for i = 0; i < x; i = i + 1 {\n"
"    for j = 0; j < y; j = j + 1 {\n"
"      if i + j > 10 {\n"
"        break\n"
"      }\n"
"      println(i + j)\n"
"    }\n"
"  }\n"
"}\n"
msgstr ""

