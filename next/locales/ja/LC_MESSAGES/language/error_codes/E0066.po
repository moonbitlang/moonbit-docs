#: ../../language/error_codes/E0066.md:1
msgid "E0066"
msgstr ""

#: ../../language/error_codes/E0066.md:3
msgid "Warning name: `prefer_fixed_array`"
msgstr ""

#: ../../language/error_codes/E0066.md:5
msgid "Suggest `FixedArray` for mutated array literal."
msgstr ""

#: ../../language/error_codes/E0066.md:7
msgid ""
"This warning is emitted when an array literal is created and then "
"mutated. Consider using `FixedArray` to better express intent."
msgstr ""

#: ../../language/error_codes/E0066.md:10
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0066.md:12
msgid ""
"test {\n"
"  let xs = [1, 2, 3]\n"
"  xs[0] = 4\n"
"  inspect(xs[0], content=\"4\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0066.md:16
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0066.md:18
msgid "Annotate the array literal as `FixedArray`:"
msgstr ""

#: ../../language/error_codes/E0066.md:20
msgid ""
"test {\n"
"  let xs : FixedArray[Int] = [1, 2, 3]\n"
"  xs[0] = 4\n"
"  inspect(xs[0], content=\"4\")\n"
"}\n"
msgstr ""

