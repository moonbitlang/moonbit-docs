#: ../../language/error_codes/E4096.md:1
msgid "E4096"
msgstr ""

#: ../../language/error_codes/E4096.md:3
msgid ""
"String interpolation syntax is not supported for `Bytes`. Only `String` "
"supports string interpolation."
msgstr ""

#: ../../language/error_codes/E4096.md:6
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4096.md:7
msgid ""
"///|\n"
"test {\n"
"  let x : Int = 42\n"
"  let _ : Bytes = \"(\\{x})\"\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4096.md:11
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4096.md:12
msgid "To dynamically create a `Bytes`, use `Buffer` with explicit UTF-8 writes:"
msgstr ""

#: ../../language/error_codes/E4096.md:14
msgid ""
"///|\n"
"test {\n"
"  let x : Int = 42\n"
"  let buf = Buffer()\n"
"  let bytes : Bytes = buf\n"
"    ..write_string_utf8(\"(\")\n"
"    ..write_utf8(x)\n"
"    ..write_string_utf8(\")\")\n"
"    .to_bytes()\n"
"  ignore(bytes)\n"
"}\n"
msgstr ""

#~ msgid ""
#~ "test {\n"
#~ "  let x : Int = 42\n"
#~ "  let _ : Bytes = \"(\\{x})\"\n"
#~ "}"
#~ msgstr ""

#~ msgid "To dynamically create a `Bytes`, use `@buffer.T` instead:"
#~ msgstr ""

#~ msgid ""
#~ "test {\n"
#~ "  let x : Int = 42\n"
#~ "  let buf = @buffer.new()\n"
#~ "  let _ : Bytes = buf\n"
#~ "    ..write_string(\"(\")\n"
#~ "    ..write_object(x)\n"
#~ "    ..write_string(\")\")\n"
#~ "    .to_bytes()\n"
#~ "}"
#~ msgstr ""

