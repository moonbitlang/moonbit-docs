#: ../../language/error_codes/E0012.md:1
msgid "E0012"
msgstr ""

#: ../../language/error_codes/E0012.md:3
msgid "Warning name: `unreachable_code`"
msgstr ""

#: ../../language/error_codes/E0012.md:5
msgid ""
"Unreachable code. This usually happens when a `return` statement is "
"followed by more code. The `return` statement will exit the function "
"immediately, so any code after it will not be executed."
msgstr ""

#: ../../language/error_codes/E0012.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0012.md:11
msgid ""
"///|\n"
"/// Example function showing unreachable code after an early return\n"
"fn unreachable_early_return() -> Unit {\n"
"  return\n"
"  println(\"Hello, World!\") // Warning: Unreachable code\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0012.md:15
msgid ""
"///|\n"
"// Example function showing unreachable pattern matching\n"
"fn unreachable_match_pattern() -> Unit {\n"
"  match Some(1) {\n"
"    _ => println(\"_\")\n"
"    Some(a) => println(\"Some(\\{a})\") // Warning: Unreachable code\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0012.md:19
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0012.md:21
msgid "Remove the unreachable code. Or adjust the branching statements."
msgstr ""

#: ../../language/error_codes/E0012.md:23
msgid ""
"///|\n"
"fn example_execute_before_return() -> Unit {\n"
"  println(\"Hello World!\")\n"
"  return\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0012.md:27
msgid ""
"You can also swap the order of the branches in the pattern matching. If "
"the order of the branches is important, then you may want to refine the "
"first pattern so that it excludes what the second pattern covers."
msgstr ""

#: ../../language/error_codes/E0012.md:31
msgid ""
"///|\n"
"fn example_proper_order() -> Unit {\n"
"  match Some(1) {\n"
"    Some(a) => println(\"Some(\\{a})\")\n"
"    _ => println(\"_\")\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0012.md:35
msgid "Or,"
msgstr ""

#: ../../language/error_codes/E0012.md:37
msgid ""
"///|\n"
"fn example_specific_pattern() -> Unit {\n"
"  match Some(1) {\n"
"    None => println(\"_\")\n"
"    Some(a) => println(\"Some(\\{a})\")\n"
"  }\n"
"}\n"
msgstr ""

