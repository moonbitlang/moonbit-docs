#: ../../language/error_codes/E4206.md:1
msgid "E4206"
msgstr ""

#: ../../language/error_codes/E4206.md:3
msgid "Compiler diagnostic name: `must_implement_one`."
msgstr ""

#: ../../language/error_codes/E4206.md:5
msgid ""
"The `#must_implement_one` trait attribute requires each implementation to"
" provide at least one method from the specified set. If the "
"implementation relies only on defaults for all required methods, the "
"compiler reports this error."
msgstr ""

#: ../../language/error_codes/E4206.md:9
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4206.md:11
msgid ""
"///|\n"
"type Token\n"
"\n"
"///|\n"
"#must_implement_one(render)\n"
"pub(open) trait Render {\n"
"  render(Self) -> String = _\n"
"  debug(Self) -> String = _\n"
"}\n"
"\n"
"///|\n"
"impl Render with render(_) {\n"
"  \"rendered\"\n"
"}\n"
"\n"
"///|\n"
"impl Render with debug(_) {\n"
"  \"debug\"\n"
"}\n"
"\n"
"///|\n"
"pub impl Render for Token with debug(_) {\n"
"  \"token\"\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4206.md:15
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4206.md:17
msgid "Implement at least one of the methods named by `#must_implement_one`."
msgstr ""

#: ../../language/error_codes/E4206.md:19
msgid ""
"///|\n"
"type Token\n"
"\n"
"///|\n"
"#must_implement_one(render)\n"
"pub(open) trait Render {\n"
"  render(Self) -> String = _\n"
"  debug(Self) -> String = _\n"
"}\n"
"\n"
"///|\n"
"impl Render with render(_) {\n"
"  \"rendered\"\n"
"}\n"
"\n"
"///|\n"
"impl Render with debug(_) {\n"
"  \"debug\"\n"
"}\n"
"\n"
"///|\n"
"pub impl Render for Token with render(_) {\n"
"  \"token\"\n"
"}\n"
msgstr ""

