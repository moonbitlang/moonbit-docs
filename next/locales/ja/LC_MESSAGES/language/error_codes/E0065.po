#: ../../language/error_codes/E0065.md:1
msgid "E0065"
msgstr ""

#: ../../language/error_codes/E0065.md:3
msgid "Warning name: `prefer_readonly_array`"
msgstr ""

#: ../../language/error_codes/E0065.md:5
msgid "Suggest `ReadOnlyArray` for read-only array literal."
msgstr ""

#: ../../language/error_codes/E0065.md:7
msgid ""
"This warning is emitted when the compiler can infer that an array literal"
" is used in a read-only way. Consider using `ReadOnlyArray` to better "
"express intent."
msgstr ""

#: ../../language/error_codes/E0065.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0065.md:13
msgid ""
"test {\n"
"  let xs = [1, 2, 3]\n"
"  inspect(xs[0], content=\"1\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0065.md:17
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0065.md:19
msgid "Annotate the array literal as `ReadOnlyArray`:"
msgstr ""

#: ../../language/error_codes/E0065.md:21
msgid ""
"test {\n"
"  let xs : ReadOnlyArray[Int] = [1, 2, 3]\n"
"  inspect(xs[0], content=\"1\")\n"
"}\n"
msgstr ""

