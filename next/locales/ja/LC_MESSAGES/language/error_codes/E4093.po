#: ../../language/error_codes/E4093.md:1
msgid "E4093"
msgstr ""

#: ../../language/error_codes/E4093.md:3
msgid "The type is not a struct type."
msgstr ""

#: ../../language/error_codes/E4093.md:5
msgid ""
"This error occurs when you try to construct a type that is not a `struct`"
" using the `T::{ .. }` syntax."
msgstr ""

#: ../../language/error_codes/E4093.md:8
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4093.md:10
msgid ""
"///|\n"
"priv enum Point {\n"
"  D2(Double, Double)\n"
"  D3(Double, Double, Double)\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let a = Point::{ x: 1.0, y: 2.0 }\n"
"  //      ^~~~~\n"
"  // Error: The type Point is not a struct type\n"
"  ignore(a)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4093.md:14
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4093.md:16
msgid "You should use the correct syntax to construct the type."
msgstr ""

#: ../../language/error_codes/E4093.md:18
msgid ""
"///|\n"
"priv enum Point {\n"
"  D2(Double, Double)\n"
"  D3(Double, Double, Double)\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let a = Point::D2(1.0, 2.0)\n"
"  let b = Point::D3(1.0, 2.0, 3.0)\n"
"  match a {\n"
"    D2(x, y) => {\n"
"      inspect(x, content=\"1\")\n"
"      inspect(y, content=\"2\")\n"
"    }\n"
"    D3(_, _, _) => fail(\"unexpected 3D point\")\n"
"  }\n"
"  match b {\n"
"    D2(_, _) => fail(\"unexpected 2D point\")\n"
"    D3(x, y, z) => {\n"
"      inspect(x, content=\"1\")\n"
"      inspect(y, content=\"2\")\n"
"      inspect(z, content=\"3\")\n"
"    }\n"
"  }\n"
"}\n"
msgstr ""
