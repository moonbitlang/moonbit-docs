#: ../../language/error_codes/E4118.md:1
msgid "E4118"
msgstr ""

#: ../../language/error_codes/E4118.md:3
msgid "Cannot match type with map pattern."
msgstr ""

#: ../../language/error_codes/E4118.md:5
msgid ""
"You can use map patterns on custom types, as long as they have a method "
"`get` that returns an optional value for a given key."
msgstr ""

#: ../../language/error_codes/E4118.md:8
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4118.md:10
msgid ""
"///|\n"
"priv struct MyMap {}\n"
"\n"
"///|\n"
"test {\n"
"  let map : MyMap = {}\n"
"  match map {\n"
"    { \"a\": a, .. } => println(\"a: \\{a}\")\n"
"    //^~~~~~~~~~~~~~\n"
"    // Error: Please implement method `get` for type MyMap to match it "
"with map pattern.\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4118.md:14
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4118.md:16
msgid "Implement the `get` method as suggested in the error message."
msgstr ""

#: ../../language/error_codes/E4118.md:18
msgid ""
"///|\n"
"priv struct MyMap {\n"
"  entries : Map[String, Int]\n"
"}\n"
"\n"
"///|\n"
"fn MyMap::get(self : MyMap, key : String) -> Int? {\n"
"  self.entries.get(key)\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let map : MyMap = { entries: { \"a\": 1, \"b\": 2, \"c\": 3 } }\n"
"  match map {\n"
"    { \"a\": a, .. } => println(\"a: \\{a}\")\n"
"    _ => println(\"missing\")\n"
"  }\n"
"}\n"
msgstr ""
