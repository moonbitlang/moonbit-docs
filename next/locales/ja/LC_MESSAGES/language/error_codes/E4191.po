#: ../../language/error_codes/E4191.md:1
msgid "E4191"
msgstr ""

#: ../../language/error_codes/E4191.md:3
msgid "Compiler diagnostic name: `mbt_check_non_test_toplevel`."
msgstr ""

#: ../../language/error_codes/E4191.md:5
msgid "Non-test toplevel in an `mbt check` documentation block."
msgstr ""

#: ../../language/error_codes/E4191.md:7
msgid ""
"Code fences marked as `mbt check` in doc comments are treated as "
"document-test blocks. These blocks should contain test toplevels, such as"
" `test { ... }`. Ordinary toplevel declarations are skipped and reported "
"with this diagnostic."
msgstr ""

#: ../../language/error_codes/E4191.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4191.md:13
msgid "The following `mbt check` block declares a normal helper function:"
msgstr ""

#: ../../language/error_codes/E4191.md:15
msgid ""
"/// Returns the answer.\n"
"///\n"
"/// ```mbt check\n"
"/// fn helper() -> Int {\n"
"///   42\n"
"/// }\n"
"/// ```\n"
"pub fn answer() -> Int {\n"
"  42\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4191.md:19
msgid "MoonBit will report an error."
msgstr ""

#: ../../language/error_codes/E4191.md:21
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4191.md:23
msgid "Move the checked code into a `test { ... }` block:"
msgstr ""

#: ../../language/error_codes/E4191.md:25
msgid ""
"/// Returns the answer.\n"
"///\n"
"/// ```mbt check\n"
"/// test {\n"
"///   inspect(answer(), content=\"42\")\n"
"/// }\n"
"/// ```\n"
"pub fn answer() -> Int {\n"
"  42\n"
"}\n"
msgstr ""

