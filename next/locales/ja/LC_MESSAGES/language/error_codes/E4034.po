#: ../../language/error_codes/E4034.md:1
msgid "E4034"
msgstr ""

#: ../../language/error_codes/E4034.md:3
msgid "Multiple possible struct types detected, please add more annotation."
msgstr ""

#: ../../language/error_codes/E4034.md:5
msgid "Erroneous Example"
msgstr ""

#: ../../language/error_codes/E4034.md:7
msgid ""
"pub struct S {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"pub struct T {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"pub fn make() -> Unit {\n"
"  let _ = { x: 2, y: 1 }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4034.md:11
msgid ""
"The example above tries to assign a struct with fields `x` and `y` to a "
"variable `c`, but this field combination matches both `S` and `T` types, "
"giving the following error on line 4:"
msgstr ""

#: ../../language/error_codes/E4034.md:14
msgid ""
"Multiple possible struct types detected: T, S, please add more "
"annotation.\n"
msgstr ""

#: ../../language/error_codes/E4034.md:18
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4034.md:20
msgid "Disambiguate the struct type by adding a type annotation:"
msgstr ""

#: ../../language/error_codes/E4034.md:22
msgid ""
"pub struct S {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"pub struct T {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"pub let c : S = { x: 2, y: 1 }\n"
"pub let c2 : S = S::{ x: 2, y: 1 }\n"
"pub let t : T = { x: 0, y: 0 }\n"
msgstr ""

#~ msgid ""
#~ "fn main {\n"
#~ "  struct S { x : Int; y : Int }\n"
#~ "  struct T { x : Int; y : Int }\n"
#~ "  let c = { x: 2, y: 1 }\n"
#~ "}\n"
#~ msgstr ""

#~ msgid ""
#~ "fn main {\n"
#~ "  struct S { x : Int; y : Int }\n"
#~ "  struct T { x : Int; y : Int }\n"
#~ "  let c : S = { x: 2, y: 1 }\n"
#~ "  let c2 = S::{ x : 2, y : 1 }\n"
#~ "}"
#~ msgstr ""

