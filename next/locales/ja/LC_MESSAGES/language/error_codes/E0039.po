#: ../../language/error_codes/E0039.md:1
msgid "E0039"
msgstr ""

#: ../../language/error_codes/E0039.md:3
msgid "Warning name: `missing_reasoning`"
msgstr ""

#: ../../language/error_codes/E0039.md:5
msgid ""
"This warning is emitted for a proof-checked `for` loop that has no "
"`proof_reasoning` clause. Proof reasoning records the argument that "
"explains why the loop invariants are maintained and why the loop result "
"satisfies the surrounding contract."
msgstr ""

#: ../../language/error_codes/E0039.md:10
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0039.md:12
msgid "The loop does not have a `proof_reasoning` clause."
msgstr ""

#: ../../language/error_codes/E0039.md:14
msgid ""
"///|\n"
"fn fib(n : Int) -> UInt64 {\n"
"  for i = 0, a = 0UL, b = 1UL; i < n; i = i + 1, a = b, b = a + b {\n"
"\n"
"  } nobreak {\n"
"    b\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0039.md:18
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0039.md:20
msgid "Add some proof reasoning."
msgstr ""

#: ../../language/error_codes/E0039.md:22
msgid ""
"///|\n"
"fn fib(n : Int) -> UInt64 {\n"
"  for i = 0, a = 0UL, b = 1UL; i < n; i = i + 1, a = b, b = a + b {\n"
"\n"
"  } nobreak {\n"
"    b\n"
"  } where {\n"
"    proof_reasoning: (\n"
"      #|The variables `a` and `b` represent consecutive Fibonacci "
"numbers, \n"
"      #|so `a` is always less than or equal to `b`.\n"
"      #|\n"
"    ),\n"
"  }\n"
"}\n"
msgstr ""
