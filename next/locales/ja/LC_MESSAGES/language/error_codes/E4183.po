#: ../../language/error_codes/E4183.md:1
msgid "E4183"
msgstr ""

#: ../../language/error_codes/E4183.md:3
msgid "Compiler diagnostic name: `regex_interpolation_is_not_supported`."
msgstr ""

#: ../../language/error_codes/E4183.md:5
msgid "Regex interpolation is not supported in `lexmatch` patterns."
msgstr ""

#: ../../language/error_codes/E4183.md:7
msgid ""
"`lexmatch` patterns are compiled as part of the match. They must be known"
" as literal regex patterns instead of being built with string or regex "
"interpolation."
msgstr ""

#: ../../language/error_codes/E4183.md:11
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4183.md:13
msgid ""
"///|\n"
"pub fn match_text(text : String, part : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    (\"\\{part}\", _) => ()\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4183.md:17
msgid "The regex pattern tries to interpolate `part`."
msgstr ""

#: ../../language/error_codes/E4183.md:19
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4183.md:21
msgid ""
"Use a literal pattern in the `lexmatch` case. For dynamic regex matching,"
" build a regex value and use a regex match expression instead of "
"`lexmatch`."
msgstr ""

#: ../../language/error_codes/E4183.md:24
msgid ""
"///|\n"
"pub fn match_text(text : String) -> Unit {\n"
"  lexmatch text with longest {\n"
"    (\"abc\", _) => ()\n"
"    _ => ()\n"
"  }\n"
"}\n"
msgstr ""
