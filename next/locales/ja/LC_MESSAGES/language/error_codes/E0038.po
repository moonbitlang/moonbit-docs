#: ../../language/error_codes/E0038.md:1
msgid "E0038"
msgstr ""

#: ../../language/error_codes/E0038.md:3
msgid "Warning name: `missing_invariant`"
msgstr ""

#: ../../language/error_codes/E0038.md:5
msgid ""
"This warning is emitted for a proof-checked `for` loop that has no "
"`proof_invariant` clause. A loop invariant records the facts that must "
"hold before and after every iteration, so the verifier can reason about "
"the loop body and the `nobreak` result."
msgstr ""

#: ../../language/error_codes/E0038.md:10
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E0038.md:12
msgid "The loop does not have a `proof_invariant` clause."
msgstr ""

#: ../../language/error_codes/E0038.md:14
msgid ""
"///|\n"
"fn fib(n : Int) -> UInt64 {\n"
"  for i = 0, a = 0UL, b = 1UL; i < n; i = i + 1, a = b, b = a + b {\n"
"\n"
"  } nobreak {\n"
"    b\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0038.md:18
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E0038.md:20
msgid "Add some proof invariants."
msgstr ""

#: ../../language/error_codes/E0038.md:22
msgid ""
"///|\n"
"fn fib(n : Int) -> UInt64 {\n"
"  for i = 0, a = 0UL, b = 1UL; i < n; i = i + 1, a = b, b = a + b {\n"
"\n"
"  } nobreak {\n"
"    b\n"
"  } where {\n"
"    proof_invariant: a <= b,\n"
"  }\n"
"}\n"
msgstr ""
