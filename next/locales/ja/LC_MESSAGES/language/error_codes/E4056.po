#: ../../language/error_codes/E4056.md:1
msgid "E4056"
msgstr ""

#: ../../language/error_codes/E4056.md:3
msgid "Compiler diagnostic name: `method_duplicate`."
msgstr ""

#: ../../language/error_codes/E4056.md:5
msgid ""
"Method has already been defined. A type cannot define two methods with "
"the same name and receiver because a method call would have no single "
"body to resolve to."
msgstr ""

#: ../../language/error_codes/E4056.md:8
msgid "Erroneous example"
msgstr ""

#: ../../language/error_codes/E4056.md:10
msgid ""
"///|\n"
"struct Point {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"///|\n"
"fn Point::to_string(self : Point) -> String {\n"
"  \"(\" + self.x.to_string() + \",\" + self.y.to_string() + \")\"\n"
"}\n"
"\n"
"///|\n"
"fn Point::to_string(self : Point) -> String {\n"
"  \"<\" + self.x.to_string() + \",\" + self.y.to_string() + \">\"\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4056.md:14
msgid "Suggestion"
msgstr ""

#: ../../language/error_codes/E4056.md:16
msgid "Remove the duplicate method and keep only one method:"
msgstr ""

#: ../../language/error_codes/E4056.md:18
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"///|\n"
"fn Point::to_string(self : Point) -> String {\n"
"  \"(\" + self.x.to_string() + \",\" + self.y.to_string() + \")\"\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let point : Point = { x: 1, y: 2 }\n"
"  inspect(point.to_string(), content=\"(1,2)\")\n"
"}\n"
msgstr ""
