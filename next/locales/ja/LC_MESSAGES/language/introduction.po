msgid ""
"The following are the reserved keywords. Using them would introduce a "
"warning. They might be turned into keywords in the future."
msgstr "以下は予約語です。使用すると警告が出ます。将来的にキーワードになる可能性があります。"

#: ../../language/introduction.md:102
msgid ""
"[\n"
"  \"module\", \"move\", \"ref\", \"static\", \"super\", \"unsafe\", \"use\","
" \"where\", \"await\",\n"
"  \"dyn\", \"abstract\", \"do\", \"final\", \"macro\", \"override\", "
"\"typeof\", \"virtual\", \"yield\",\n"
"  \"local\", \"method\", \"alias\", \"assert\", \"package\", \"recur\", "
"\"using\", \"enumview\",\n"
"  \"isnot\", \"define\", \"downcast\", \"inherit\", \"member\", "
"\"namespace\", \"static\", \"upcast\",\n"
"  \"use\", \"void\", \"lazy\", \"include\", \"mixin\", \"protected\", "
"\"sealed\", \"constructor\",\n"
"  \"atomic\", \"volatile\", \"anyframe\", \"anytype\", \"asm\", \"await\", "
"\"comptime\", \"errdefer\",\n"
"  \"export\", \"opaque\", \"orelse\", \"resume\", \"threadlocal\", "
"\"unreachable\", \"dynclass\",\n"
"  \"dynobj\", \"dynrec\", \"var\", \"finally\", \"noasync\",\n"
"]\n"
msgstr ""
"[\n"
"  \"module\", \"move\", \"ref\", \"static\", \"super\", \"unsafe\", \"use\","
" \"where\", \"await\",\n"
"  \"dyn\", \"abstract\", \"do\", \"final\", \"macro\", \"override\", "
"\"typeof\", \"virtual\", \"yield\",\n"
"  \"local\", \"method\", \"alias\", \"assert\", \"package\", \"recur\", "
"\"using\", \"enumview\",\n"
"  \"isnot\", \"define\", \"downcast\", \"inherit\", \"member\", "
"\"namespace\", \"static\", \"upcast\",\n"
"  \"use\", \"void\", \"lazy\", \"include\", \"mixin\", \"protected\", "
"\"sealed\", \"constructor\",\n"
"  \"atomic\", \"volatile\", \"anyframe\", \"anytype\", \"asm\", \"await\", "
