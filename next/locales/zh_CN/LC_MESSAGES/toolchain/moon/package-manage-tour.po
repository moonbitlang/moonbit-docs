#~ msgstr "moon update 命令行"

#~ msgid "moon new"
#~ msgstr "moon new"

#~ msgid "add deps"
#~ msgstr "添加依赖"

#~ msgid "Add local dependencies"
#~ msgstr "添加本地依赖"

#~ msgid ""
#~ "In addition to modules from mooncakes.io, you can also add local modules "
#~ "as dependencies. This is useful when developing multiple related modules "
#~ "on your local machine or when working with modules that are not published "
