#: ../../language/error_codes/E4127.md:1
msgid "E4127"
msgstr ""

#: ../../language/error_codes/E4127.md:3
msgid "Type is not an error type."
msgstr "类型不是错误类型。"

#: ../../language/error_codes/E4127.md:5
msgid ""
"MoonBit only allows error types (defined with `suberror`) to appear after"
" `raise` in the return type of a function."
msgstr "MoonBit 只允许错误类型（使用 `suberror` 定义）出现在函数返回类型的 `raise` 之后。"

#: ../../language/error_codes/E4127.md:8
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E4127.md:10
msgid ""
"pub fn may_raise_error() -> Unit raise String {\n"
"  return\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4127.md:14
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E4127.md:16
msgid "You can wrap the type you wish to raise in an error type:"
msgstr "您可以将希望抛出的类型包装在错误类型中："

#: ../../language/error_codes/E4127.md:18
msgid ""
"pub suberror StringError {\n"
"  StringError(String)\n"
"}\n"
"\n"
"pub fn may_raise_error() -> Unit raise StringError {\n"
"  raise StringError(\"Failed\")\n"
"}\n"
msgstr ""

