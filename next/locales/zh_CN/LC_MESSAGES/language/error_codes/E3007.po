#: ../../language/error_codes/E3007.md:1
msgid "E3007"
msgstr ""

#: ../../language/error_codes/E3007.md:3
msgid ""
"Wrong location of `..` in a record pattern. Put `..` after the last field"
" in the pattern."
msgstr "记录模式中的 `..` 位置错误。请将 `..` 放在模式中最后一个字段之后。"

#: ../../language/error_codes/E3007.md:6
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E3007.md:8
msgid ""
"pub(all) struct S {\n"
"  a : Int\n"
"  b : Int\n"
"  c : Int\n"
"}\n"
"\n"
"fn sum_selected(s : S) -> Int {\n"
"  let { a, .., c } = s\n"
"  a + c\n"
"}\n"
"\n"
"test {\n"
"  inspect(sum_selected({ a: 1, b: 2, c: 3 }), content=\"4\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3007.md:12
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E3007.md:14
msgid ""
"Move `..` to the end of the record pattern, after all fields that you "
"want to bind:"
msgstr "将 `..` 移到记录模式的末尾，放在所有需要绑定的字段之后："

#: ../../language/error_codes/E3007.md:17
msgid ""
"///|\n"
"pub(all) struct S {\n"
"  a : Int\n"
"  b : Int\n"
"  c : Int\n"
"}\n"
"\n"
"///|\n"
"fn sum_selected(s : S) -> Int {\n"
"  let { a, c, .. } = s\n"
"  a + c\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(sum_selected({ a: 1, b: 2, c: 3 }), content=\"4\")\n"
"}\n"
msgstr ""
