#: ../../language/error_codes/E3009.md:1
msgid "E3009"
msgstr ""

#: ../../language/error_codes/E3009.md:3
msgid ""
"A record pattern cannot contain only `..`. Use the wildcard pattern `_` "
"instead."
msgstr "记录模式不能只包含 `..`。请改用通配符模式 `_`。"

#: ../../language/error_codes/E3009.md:5
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E3009.md:7
msgid ""
"///|\n"
"struct Point {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"///|\n"
"fn process_point(p : Point) -> Unit {\n"
"  match p {\n"
"    { .. } => println(\"Got a point\")\n"
"    //^~~~~~\n"
"    // Error: Struct pattern cannot contain only `..`, use wildcard "
"pattern `_` instead.\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3009.md:11
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E3009.md:13
msgid "Use the wildcard pattern `_` instead of `{ .. }`:"
msgstr "使用通配符模式 `_` 代替 `{ .. }`："

#: ../../language/error_codes/E3009.md:15
msgid ""
"///|\n"
"pub(all) struct Point {\n"
"  x : Int\n"
"  y : Int\n"
"}\n"
"\n"
"///|\n"
"fn process_point(p : Point) -> Unit {\n"
"  match p {\n"
"    _ => println(\"Got a point\")\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let p : Point = { x: 0, y: 1 }\n"
"  process_point(p)\n"
"  process_y_axis(p)\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3009.md:19
msgid ""
"You can also use `{ .. }` along with other fields if you want to match "
"specific fields:"
msgstr "如果你想匹配特定字段的话，你也可以与其他字段一起使用 `{ .. }`："

#: ../../language/error_codes/E3009.md:21
msgid ""
"///|\n"
"fn process_y_axis(p : Point) -> Unit {\n"
"  match p {\n"
"    { x: 0, .. } => println(\"Point on y-axis\")\n"
"    _ => println(\"Other point\")\n"
"  }\n"
"}\n"
msgstr ""
