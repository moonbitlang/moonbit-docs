#: ../../language/error_codes/E0033.md:1
msgid "E0033"
msgstr ""

#: ../../language/error_codes/E0033.md:3
msgid "Warning name: `text_segment_excceed`"
msgstr ""

#: ../../language/error_codes/E0033.md:5
msgid "Text segment exceed the line or column limits."
msgstr "文本片段超出行或列限制。"

#: ../../language/error_codes/E0033.md:7
msgid ""
"This warning is emitted when a text segment in source code exceeds "
"internal line/column limits used by the compiler tooling. Consider "
"splitting the text into smaller pieces."
msgstr "当源代码中的文本片段超过编译器工具使用的内部行/列限制时，会发出此警告。建议将文本拆分成更小的片段。"

#~ msgid ""
#~ "This page has no checked source "
#~ "example because a minimal reproduction "
#~ "requires an extremely long line or "
#~ "enough lines to exceed the compiler's"
#~ " segment limits."
#~ msgstr "此页面没有受检查的源码示例，因为最小复现需要极长的单行，或足够多的行来超过编译器的片段限制。"

