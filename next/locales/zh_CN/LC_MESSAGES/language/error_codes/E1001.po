#: ../../language/error_codes/E1001.md:1
msgid "E1001"
msgstr ""

#: ../../language/error_codes/E1001.md:3
msgid "Compiler diagnostic name: `internal`."
msgstr ""

#: ../../language/error_codes/E1001.md:5
msgid ""
"An internal compiler error occurred. Usually this means you have "
"discovered a bug in the compiler."
msgstr "发生了编译器内部错误。通常这意味着你发现了编译器中的 bug。"

#: ../../language/error_codes/E1001.md:8
msgid ""
"A bug report containing the error description and relevant code would be "
"greatly appreciated. You can submit the bug report here:"
msgstr "如果能提交包含错误描述和相关代码的 bug 报告，我们会非常感谢。你可以在这里提交报告："

#: ../../language/error_codes/E1001.md:11
msgid "<https://github.com/moonbitlang/moonbit-docs/issues/new?labels=bug,ICE>"
msgstr ""

#: ../../language/error_codes/E1001.md:13
msgid "This internal diagnostic has no checked source example."
msgstr "此内部诊断没有受检查的源码示例。"
