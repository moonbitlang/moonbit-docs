#: ../../language/error_codes/E4154.md:1
msgid "E4154"
msgstr ""

#: ../../language/error_codes/E4154.md:3
msgid "Non-constant `enum` with custom tag value."
msgstr "自定义标记值的非常量枚举 `enum`。"

#: ../../language/error_codes/E4154.md:5
msgid "MoonBit supports customizing the integer representation of constructors:"
msgstr "MoonBit 支持自定义枚举构造器的整数表示："

#: ../../language/error_codes/E4154.md:7
msgid ""
"enum Flag {\n"
"  A = 1\n"
"  B = 2\n"
"  C = 3\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4154.md:15
msgid ""
"However, only constant `enum` values (where all constructors have no "
"payload) can have custom tags. Otherwise this error will be reported."
msgstr "但是，只有常量 `enum` 值（所有构造器都没有负载）才能有自定义标记值。否则编译器会产生本错误。"

#: ../../language/error_codes/E4154.md:18
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E4154.md:19
msgid ""
"enum Bad {\n"
"  A = 1\n"
"  B = 2\n"
"  C(Int)\n"
"}"
msgstr ""

#: ../../language/error_codes/E4154.md:23
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E4154.md:25
msgid "Remove the payload, or remove the custom tag values:"
msgstr "移除构造器负载，或移除自定义标记值："

#: ../../language/error_codes/E4154.md:27
msgid ""
"pub enum Good {\n"
"  A = 1\n"
"  B = 2\n"
"  C = 3\n"
"}\n"
"\n"
"pub fn all() -> (Good, Good, Good) {\n"
"  (A, B, C)\n"
"}\n"
msgstr ""
