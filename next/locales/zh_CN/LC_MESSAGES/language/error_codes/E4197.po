#: ../../language/error_codes/E4197.md:1
msgid "E4197"
msgstr "E4197"

#: ../../language/error_codes/E4197.md:3
msgid "Compiler diagnostic name: `cannot_match_struct_constr`."
msgstr "编译器诊断名称：`cannot_match_struct_constr`。"

#: ../../language/error_codes/E4197.md:5
#, fuzzy
msgid ""
"A struct constructor is a function, not a pattern constructor. It can be "
"called to create a value, but it cannot be used in a `match` pattern."
msgstr "由 `struct` 声明的构造器是构造函数，而不是模式构造器。它可以被调用来创建值，但不能在 `match` 模式中使用。"

#: ../../language/error_codes/E4197.md:8
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E4197.md:10
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"}\n"
"\n"
"///|\n"
"fn Point::Point(x : Int) -> Point {\n"
"  { x, }\n"
"}\n"
"\n"
"///|\n"
"fn read(point : Point) -> Int {\n"
"  match point {\n"
"    Point(x) => x\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let _ = read(Point(1))\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4197.md:14
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E4197.md:16
msgid ""
"Read the struct fields directly, or use another pattern that does not "
"call the constructor function."
msgstr "直接读取结构体字段，或使用另一种不会调用构造函数的模式。"

#: ../../language/error_codes/E4197.md:19
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"}\n"
"\n"
"///|\n"
"fn Point::Point(x : Int) -> Point {\n"
"  { x, }\n"
"}\n"
"\n"
"///|\n"
"fn read(point : Point) -> Int {\n"
"  point.x\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(read(Point(3)), content=\"3\")\n"
"}\n"
msgstr ""
