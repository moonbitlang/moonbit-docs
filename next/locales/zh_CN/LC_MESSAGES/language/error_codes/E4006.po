#~ "  fn helper() {\n"
#~ "    1 + 1\n"
#~ "  }\n"
#~ "\n"
#~ "  fn helper() { // E4006: local function 'helper' is already defined\n"
#~ "    2 + 2\n"
#~ "  }\n"
#~ "\n"
#~ "  helper()\n"
#~ "}\n"
#~ msgstr ""

