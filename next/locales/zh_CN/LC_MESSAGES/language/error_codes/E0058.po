#: ../../language/error_codes/E0058.md:1
msgid "E0058"
msgstr "E0058"

#: ../../language/error_codes/E0058.md:3
msgid "Warning name: `unused_non_capturing`"
msgstr "警告名称：`unused_non_capturing`"

#: ../../language/error_codes/E0058.md:5
msgid "Unnecessary non-capturing group in regex."
msgstr "正则表达式中存在不必要的非捕获分组。"

#: ../../language/error_codes/E0058.md:7
msgid ""
"This warning is emitted when a regex contains a non-capturing group that "
"is not needed. Consider simplifying the regex by removing the redundant "
"group."
msgstr "当正则表达式包含不需要的非捕获分组时发出此警告。可删除多余分组以简化正则。"

#: ../../language/error_codes/E0058.md:10
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E0058.md:12
msgid ""
"///|\n"
"test {\n"
"  let text = \"xxabcyy\"\n"
"  if text =~ (re\"a(?:b)c\", before~, after~) {\n"
"    inspect(before, content=\"xx\")\n"
"    inspect(after, content=\"yy\")\n"
"  } else {\n"
"    fail(\"\")\n"
"  }\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0058.md:16
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E0058.md:18
msgid ""
"Remove the redundant non-capturing group. If the matched part is needed, "
"bind that regex subexpression with `as`. Regex named capture groups are "
"available through `Regex::execute` and `MatchResult::named_group`, but "
"they are not binders in `=~` expressions:"
msgstr ""

#: ../../language/error_codes/E0058.md:23
msgid ""
"///|\n"
"test {\n"
"  let text = \"xxabcyy\"\n"
"  if text =~ (re\"a\" + (re\"b\" as middle) + re\"c\", before~, after~) {"
"\n"
"    inspect(before, content=\"xx\")\n"
"    inspect(middle, content=\"b\")\n"
"    inspect(after, content=\"yy\")\n"
"  } else {\n"
"    fail(\"\")\n"
"  }\n"
"}\n"
msgstr ""

#~ msgid ""
#~ "///|\n"
#~ "test {\n"
#~ "  let text = \"xxabcyy\"\n"
#~ "  lexmatch text {\n"
#~ "    (before, \"a\" \"(?:b)\" \"c\", after) => {\n"
#~ "      inspect(before, content=\"xx\")\n"
#~ "      inspect(after, content=\"yy\")\n"
#~ "    }\n"
#~ "    _ => fail(\"\")\n"
#~ "  }\n"
#~ "}\n"
#~ msgstr ""

#~ msgid "Remove the redundant non-capturing group:"
#~ msgstr "移除多余的非捕获分组："

#~ msgid ""
#~ "///|\n"
#~ "test {\n"
#~ "  let text = \"xxabcyy\"\n"
#~ "  lexmatch text {\n"
#~ "    (before, \"a\" \"b\" \"c\", after) => {\n"
#~ "      inspect(before, content=\"xx\")\n"
#~ "      inspect(after, content=\"yy\")\n"
#~ "    }\n"
#~ "    _ => fail(\"\")\n"
#~ "  }\n"
#~ "}\n"
#~ msgstr ""

#~ msgid ""
#~ "Remove the redundant non-capturing "
#~ "group. If the matched part is "
#~ "needed, bind that regex subexpression "
#~ "with `as`:"
#~ msgstr ""
