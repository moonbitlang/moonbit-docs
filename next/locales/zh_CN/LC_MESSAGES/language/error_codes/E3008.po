#: ../../language/error_codes/E3008.md:1
msgid "E3008"
msgstr ""

#: ../../language/error_codes/E3008.md:3
msgid ""
"There are multiple `..` patterns in an array pattern. Use at most one "
"`..` in each array pattern."
msgstr "数组模式中有多个 `..` 模式。每个数组模式中最多只能使用一个 `..`。"

#: ../../language/error_codes/E3008.md:6
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E3008.md:8
msgid ""
"fn outer_sum(array : Array[Int]) -> Int {\n"
"  let [fst, .., .., snd] = array\n"
"  fst + snd\n"
"}\n"
"\n"
"test {\n"
"  inspect(outer_sum([1, 2, 3, 4, 5]), content=\"6\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E3008.md:12
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E3008.md:14
msgid "Remove the extra `..` pattern."
msgstr "移除多余的 `..` 模式。"

#: ../../language/error_codes/E3008.md:16
msgid ""
"///|\n"
"fn outer_sum(array : Array[Int]) -> Int {\n"
"  match array {\n"
"    [fst, .., snd] => fst + snd\n"
"    _ => 0\n"
"  }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(outer_sum([1, 2, 3, 4, 5]), content=\"6\")\n"
"}\n"
msgstr ""
