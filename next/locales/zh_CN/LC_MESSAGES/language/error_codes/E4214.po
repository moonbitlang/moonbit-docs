#: ../../language/error_codes/E4214.md:1
msgid "E4214"
msgstr ""

#: ../../language/error_codes/E4214.md:3
msgid "Compiler diagnostic name: `cannot_extend_non_extensible_enum`."
msgstr ""

#: ../../language/error_codes/E4214.md:5
msgid "Only `extenum` declarations can be extended."
msgstr "只有 `extenum` 声明可以被扩展。"

#: ../../language/error_codes/E4214.md:7
msgid ""
"Regular `enum` declarations are closed: all of their constructors must "
"appear in the original declaration. To add constructors later, declare "
"the type as `extenum` from the start."
msgstr ""
"普通 `enum` 声明是封闭的：它的所有构造器都必须出现在原始声明中。"
"如果需要之后再添加构造器，请一开始就将该类型声明为 `extenum`。"

#: ../../language/error_codes/E4214.md:11
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E4214.md:13
msgid ""
"enum Event {\n"
"  Started\n"
"}\n"
"\n"
"extenum Event += {\n"
"  Stopped\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4214.md:23
msgid "The code tries to extend a regular `enum`."
msgstr "这段代码尝试扩展一个普通 `enum`。"

#: ../../language/error_codes/E4214.md:25
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E4214.md:27
msgid "Declare the type as `extenum` before extending it."
msgstr "在扩展类型之前，先将其声明为 `extenum`。"

#: ../../language/error_codes/E4214.md:29
msgid ""
"extenum Event {\n"
"  Started\n"
"}\n"
"\n"
"extenum Event += {\n"
"  Stopped\n"
"}\n"
msgstr ""
