#: ../../language/error_codes/E4117.md:1
msgid "E4117"
msgstr ""

#: ../../language/error_codes/E4117.md:3
msgid "Function with labelled arguments can only be applied directly."
msgstr "只能直接应用带标签的函数。"

#: ../../language/error_codes/E4117.md:5
msgid ""
"This means you cannot pass a function with labelled arguments as an "
"argument to another function."
msgstr "这意味着您不能将带标签的函数作为参数传递给另一个函数。"

#: ../../language/error_codes/E4117.md:8
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E4117.md:10
msgid ""
"///|\n"
"pub fn accumulate(acc~ : Int, value : Int) -> Int {\n"
"  acc + value\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let xs = [1, 2, 3, 4, 5]\n"
"  let sum = xs.fold(init=0, accumulate)\n"
"  //                       ^~~~~~~~~~~~\n"
"  // Error: Function with labelled arguments can only be applied "
"directly.\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4117.md:14
msgid ""
"Use [Partial "
"Applications](https://docs.moonbitlang.com/en/latest/language/fundamentals.html"
"#partial-applications) to create a function value without labelled "
"arguments."
msgstr ""
"使用[部分应用](https://docs.moonbitlang.com/en/latest/language/fundamentals.html"
"#partial-applications) 创建一个不带标签参数的函数值。"

#: ../../language/error_codes/E4117.md:17
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E4117.md:19
msgid ""
"///|\n"
"pub fn accumulate(acc~ : Int, value : Int) -> Int {\n"
"  acc + value\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  let xs = [1, 2, 3, 4, 5]\n"
"  let sum = xs.fold(init=0, fn(acc, value) { accumulate(acc~, value) })\n"
"  inspect(sum, content=\"15\")\n"
"}\n"
msgstr ""

#~ msgid ""
#~ "///|\n"
#~ "pub fn accumulate(acc~ : Int, value : Int) -> Int {\n"
#~ "  acc + value\n"
#~ "}\n"
#~ "\n"
