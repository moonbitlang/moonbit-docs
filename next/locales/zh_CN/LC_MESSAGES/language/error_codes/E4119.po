#: ../../language/error_codes/E4119.md:1
msgid "E4119"
msgstr ""

#: ../../language/error_codes/E4119.md:3
msgid ""
"This diagnostic was used when a function that was not a toplevel function"
" had labelled arguments."
msgstr "当非顶层函数带有标签参数时，旧版编译器会使用此诊断。"

#: ../../language/error_codes/E4119.md:6
msgid ""
"Current MoonBit reports this pattern as [E4114](./E4114.md). See E4114 "
"for the checked examples and fixes."
msgstr "当前 MoonBit 会将这种模式报告为 [E4114](./E4114.md)。请参阅 E4114 中已检查的示例和修复方式。"

#~ msgid "Erroneous example"
#~ msgstr "错误示例"

#~ msgid ""
#~ "fn main {\n"
#~ "  fn greet(name~ : String) -> Unit {\n"
#~ "    println(\"Hello, \\{name}\")\n"
#~ "  }\n"
#~ "}"
#~ msgstr ""

#~ msgid "Suggestion"
#~ msgstr "建议"

#~ msgid ""
#~ "You can either remove the labelled "
#~ "argument, using positional argument instead:"
#~ msgstr "您可以删除带标签的参数，改用位置参数代替："

#~ msgid ""
#~ "fn main {\n"
#~ "  fn greet(name : String) -> Unit {\n"
#~ "    println(\"Hello, \\{name}\")\n"
#~ "  }\n"
#~ "  greet(\"world\")\n"
#~ "}"
#~ msgstr ""

#~ msgid "Or you can make the function a toplevel function:"
#~ msgstr "或者您可以将函数设为顶层函数："

#~ msgid ""
#~ "fn greet(name~ : String) -> Unit {\n"
#~ "  println(\"Hello, \\{name}\")\n"
#~ "}\n"
#~ "\n"
#~ "fn main {\n"
#~ "  greet(name=\"World\")\n"
#~ "}"
#~ msgstr ""
