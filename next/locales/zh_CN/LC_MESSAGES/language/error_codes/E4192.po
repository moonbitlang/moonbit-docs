#: ../../language/error_codes/E4192.md:1
msgid "E4192"
msgstr ""

#: ../../language/error_codes/E4192.md:3
msgid "Compiler diagnostic name: `invalid_moon_pkg_config`."
msgstr ""

#: ../../language/error_codes/E4192.md:5
msgid "Invalid configuration in `moon.pkg`."
msgstr "`moon.pkg` 中存在无效配置。"

#: ../../language/error_codes/E4192.md:7
msgid ""
"`moon.pkg` accepts only package-level configuration fields understood by "
"the build system. Unknown or misplaced keys are rejected so spelling "
"mistakes do not silently change how a package is built."
msgstr "`moon.pkg` 只接受构建系统能够理解的包级配置字段。未知或位置错误的键会被拒绝，以免拼写错误静默改变包的构建方式。"

#: ../../language/error_codes/E4192.md:11
msgid ""
"This error is produced while the build system reads package "
"configuration, before ordinary `moon check` diagnostic rendering is "
"available, so it is not monitored by a source-level error-code example."
msgstr "此错误在构建系统读取包配置时产生，早于普通 `moon check` 诊断渲染可用的阶段，因此不会通过源码级错误码示例监控。"

#~ msgid ""
#~ "Detailed documentation and examples for "
