#: ../../language/error_codes/E4121.md:1
msgid "E4121"
msgstr ""

#: ../../language/error_codes/E4121.md:3
msgid "The attribute (`!`, `?`, `!!` mark) cannot be used on this application."
msgstr "这个应用中不允许使用 `!`、`?` 或 `!!` 标记。"

#: ../../language/error_codes/E4121.md:5
msgid "This error occurs when:"
msgstr "这个错误发生在以下情况："

#: ../../language/error_codes/E4121.md:7
msgid "The attribute (`!`, `?`, `!!` mark) is used on a constructor."
msgstr "`!`、`?` 或 `!!` 标记用于构造函数。"

#: ../../language/error_codes/E4121.md:8
msgid "The attribute is used on a function that does not fit."
msgstr "该标记用于不适合的函数。"

#: ../../language/error_codes/E4121.md:9
msgid "`!` must be used only on an application that raises or is async."
msgstr "`!` 只能用于会引发错误或异步的函数应用。"

#: ../../language/error_codes/E4121.md:10
msgid "`!!` must be used only on an async application."
msgstr "`!!` 只能用于异步函数应用。"

#: ../../language/error_codes/E4121.md:12
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E4121.md:14
msgid ""
"///|\n"
"pub enum Err {\n"
"  IntErr(Int)\n"
"}\n"
"\n"
"///|\n"
"fn square(x : Int) -> Int {\n"
"  x * x\n"
"}\n"
"\n"
"///|\n"
"pub fn invalid_attribute() -> Unit {\n"
"  square!!(1) |> ignore()\n"
"  // Error: The attribute `!!` cannot be used on application that does "
"not raise\n"
"  // errors.\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E4121.md:18
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E4121.md:20
msgid "Remove the attribute (`!`, `?`, `!!` mark) from the application."
msgstr "从应用中移除 `!`、`?` 或 `!!` 标记。"

#: ../../language/error_codes/E4121.md:22
msgid ""
"///|\n"
"pub enum Err {\n"
"  IntErr(Int)\n"
"}\n"
"\n"
"///|\n"
"fn square(x : Int) -> Int {\n"
"  x * x\n"
"}\n"
"\n"
"///|\n"
"pub fn constructor_value() -> Err {\n"
"  IntErr(1)\n"
"}\n"
"\n"
"///|\n"
"pub fn square_value() -> Int {\n"
"  square(2)\n"
"}\n"
msgstr ""
