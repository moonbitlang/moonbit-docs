#: ../../language/error_codes/E0073.md:1
msgid "E0073"
msgstr ""

#: ../../language/error_codes/E0073.md:3
msgid "Warning name: `unnecessary_annotation`"
msgstr ""

#: ../../language/error_codes/E0073.md:5
msgid "Unnecessary type or package annotation."
msgstr "不必要的类型或包标注。"

#: ../../language/error_codes/E0073.md:7
msgid ""
"MoonBit reports this warning when a type or package qualifier repeats "
"information that is already known from context. Removing the qualifier "
"keeps the code shorter without changing the meaning."
msgstr "当类型或包限定符重复了上下文中已经明确的信息时，MoonBit 会报告此警告。移除该限定符可以让代码更简洁，而且不会改变含义。"

#: ../../language/error_codes/E0073.md:11
msgid "Erroneous example"
msgstr "错误示例"

#: ../../language/error_codes/E0073.md:13
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"}\n"
"\n"
"///|\n"
"fn make_point() -> Point {\n"
"  Point::{ x: 1 }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(make_point().x, content=\"1\")\n"
"}\n"
msgstr ""

#: ../../language/error_codes/E0073.md:17
msgid "Suggestion"
msgstr "建议"

#: ../../language/error_codes/E0073.md:19
msgid "Remove the redundant annotation."
msgstr "移除冗余标注。"

#: ../../language/error_codes/E0073.md:21
msgid ""
"///|\n"
"priv struct Point {\n"
"  x : Int\n"
"}\n"
"\n"
"///|\n"
"fn make_point() -> Point {\n"
"  { x: 1 }\n"
"}\n"
"\n"
"///|\n"
"test {\n"
"  inspect(make_point().x, content=\"1\")\n"
"}\n"
msgstr ""
