#: ../../language/error_codes/E4054.md:1
msgid "E4054"
msgstr ""

#: ../../language/error_codes/E4054.md:3
msgid "Compiler diagnostic name: `cannot_determine_self_type`."
msgstr ""

#: ../../language/error_codes/E4054.md:5
msgid ""
"Cannot determine self type of extension method. `Self` does not occur in "
"the signature of the method."
msgstr "无法确定扩展方法的 self 类型。`Self` 未出现在方法签名中。"

#: ../../language/error_codes/E4054.md:8
msgid ""
"Current MoonBit reports missing method parameter annotations through more"
" specific diagnostics, so this compatibility page has no checked source "
"example."
msgstr "当前 MoonBit 会通过更具体的诊断报告缺失的方法参数标注，因此此兼容性页面没有受检查的源码示例。"

#~ msgid "Currently, MoonBit won't emit this error."
#~ msgstr "目前，MoonBit 不会报告这个错误。"
